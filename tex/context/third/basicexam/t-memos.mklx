                              alternative=serried,
                              before=\vskip.25\baselineskip\relax,
                              after=\vskip.25\baselineskip\relax,
                              width=fit,
                              right={.~},
                              prefix=yes,% or prefixsegments=chapter:section
                              prefixsegments=section]
\setupcounter       [remark] [way=bysection]
\definedescription  [description][
                     before=\vskip.25\baselineskip\relax,
                     after=\vskip.25\baselineskip\relax,
                     alternative=serried,width=fit,
                     indenting=2em,indentnext=yes,
                     headstyle=bold,align={flushleft},]
\defineenumeration  [tips] [text=Tips,
                            headcommand=\setuptextrules[color=themecolor,rulecolor=themecolor,rulethickness=1.5\linewidth]\textrule[top],
                            before=\vskip-\baselineskip\relax,
                            after=\setuptextrules[color=themecolor,rulecolor=themecolor,rulethickness=1.5\linewidth]\textrule[bottom]\empty,
                            inbetween=,
                            width=fit,
                            right={.~},
                            prefix=yes,% or prefixsegments=chapter:section
