\setMPtext{MPFrameTitle}{\hbox spread \baselineskip{\hss\framed[frame=off]%
    {\framedtextparameter{title}}\hss}}

\defineframedtext[FrameText][
                  background=MPFrameI,       frame=off,    title=,
                  framecolor=lightthemecolor,backgroundcolor=transparentcolor,
                  rulethickness=1.5pt,       indenting={yes,2em},
                  toffset=.5\bodyfontsize, % if titlepos=1 , then toffset=\bodyfontsize
                  width=\textwidth,]

\definecounter[FrameCounter]
              [way=bychapter,
               prefix=yes,
               prefixset=chapter,
               prefixconnector=\endash,]

