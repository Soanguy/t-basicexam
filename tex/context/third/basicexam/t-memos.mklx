%%%%% \processaction 执行顺序，需要先定义这些参数

\processaction[\currentmoduleparameter{chapterstyle}]%
   [      line=>\setups{memos:chap:line},
      colorful=>\setups{memos:chap:colorful},
        madsen=>\setups{memos:chap:madsen},
        rocket=>\setups{memos:chap:rocket},
          hexa=>\setups{memos:chap:hexa},
        simple=>\setups{memos:chap:simple},
      classics=>\setups{memos:chap:classics},
  classicnovel=>\setups{memos:chap:classicnovel},
       kaolike=>\setups{memos:chap:kaolike},
       article=>\setups{memos:chap:article},
       publish=>\setups{memos:chap:publish},
          none=>\relax,
    \v!default=>\setups{memos:chap:default},
    \v!unknown=>\errorparameter{chapterstyle},]

\processaction[\currentmoduleparameter{tocstyle}][
          line=>\setups{memos:toc:line},
      colorful=>\setups{memos:toc:colorful},
        madsen=>\setups{memos:toc:madsen},
        rocket=>\setups{memos:toc:rocket},
          hexa=>\setups{memos:toc:hexa},
        simple=>\setups{memos:toc:simple},
      classics=>\setups{memos:toc:classics},
  classicnovel=>\setups{memos:toc:classicnovel},
       kaolike=>\setups{memos:toc:kaolike},
          none=>\relax,
    \v!default=>\setups{memos:toc:default},
    \v!unknown=>\errorparameter{tocstyle},]

\protect
\stopmodule
