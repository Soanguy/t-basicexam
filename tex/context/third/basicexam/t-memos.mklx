  titlecolor="\framedtextparameter{titlecolor}",
  framecolor="\framedtextparameter{framecolor}",
  numberframecolor="\framedtextparameter{numberframecolor}",
  titleframecolor="\framedtextparameter{titleframecolor}",
  numberframe=\framedtextparameter{numberframe},
  titleframe=\framedtextparameter{titleframe},
  leftframe=\framedtextparameter{leftframe},
  rightframe=\framedtextparameter{rightframe},
  topframe=\framedtextparameter{topframe},
  bottomframe=\framedtextparameter{bottomframe},
  numberratio=\framedtextparameter{numberratio},
