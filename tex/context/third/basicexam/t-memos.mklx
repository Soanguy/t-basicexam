  [MetroCard]
  [location=paragraph,
   mp=MetroBG,
   frame=off,
   leftoffset=1.8em,
   rightoffset=1.8em,
   topoffset=1.8em,
   bottomoffset=1.8em,
   color=white,
   before={\blank[big]},
   after={\blank[big]}]

\definetextbackground[FluentCard][MetroCard][mp=FluentBG,]
\definetextbackground[macOSCard] [MetroCard][mp=macOSBG,]
\definetextbackground[ModernCard][MetroCard][mp=ModernBG,]

