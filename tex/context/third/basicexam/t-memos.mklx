\startuseMPgraphic{mp:itemgroup:squares}
numeric us; path ps;
us := BodyFontSize;
ps := fullsquare scaled .5us;
draw ps shifted (.2us, -.2us) withcolor .5white  withpen pencircle scaled 1pt;
draw ps shifted (.4us, -.0us) withcolor \MPcolor{lightthemecolor}  withpen pencircle scaled 1pt;
\stopuseMPgraphic

\startuseMPgraphic{mp:itemgroup:circles}
numeric uc; path pc;
uc := BodyFontSize;
pc := fullcircle scaled .55uc;
draw pc shifted (.15uc, -.15uc) withcolor .5white  withpen pencircle scaled 1pt;
draw pc       withcolor \MPcolor{lightthemecolor}  withpen pencircle scaled 1pt;
\stopuseMPgraphic

\startuseMPgraphic{mp:itemgroup:square}
numeric us; path ps;
us := BodyFontSize;
ps := fullsquare scaled .6us;
fill ps shifted (.2us, -.2us) withcolor .5white;
fill ps withcolor \MPcolor{lightthemecolor};
\stopuseMPgraphic

\startuseMPgraphic{mp:itemgroup:circle}
numeric uc; path pc;
uc := BodyFontSize;
pc := fullcircle scaled .65uc;
fill pc shifted (.15uc, -.15uc) withcolor .5white;
fill pc withcolor \MPcolor{lightthemecolor};
\stopuseMPgraphic

\startuseMPgraphic{sym:squares-random}
  save height , depth ;
  height := \the \bodyfontsize * \currentfontscale ;
  depth  := \the \strutdepth ;
  path squaresrandom;
  squaresrandom   := fullsquare scaled .6height randomized 1pt;
  draw squaresrandom crossingunder (fullsquare scaled height)
                     withpen pencircle scaled 2pt
                     withcolor \MPcolor{\itemgroupparameter{color}};
  draw  (fullsquare scaled height)
             withpen pencircle scaled 0pt withtransparency (1,0) ;
\stopuseMPgraphic
\startuniqueMPgraphic{sym:square}
  save height , depth ;
  height := \the \bodyfontsize * \currentfontscale ;
  depth  := \the \strutdepth ;
  path square;
  square   := fullsquare scaled .6height;
  draw square crossingunder (fullsquare scaled height)
              withpen pencircle scaled 1pt
              withcolor \MPcolor{\itemgroupparameter{color}};
  draw  (fullsquare scaled height)
             withpen pencircle scaled 0pt withtransparency (1,0) ;
\stopuniqueMPgraphic
\startuniqueMPgraphic{sym:circle}
  save height , depth ;
  height := \the \bodyfontsize * \currentfontscale ;
  depth  := \the \strutdepth ;
  path circle;
  circle   := fullcircle scaled .6height;
  draw circle crossingunder (fullsquare scaled height)
              withpen pencircle scaled 1pt
              withcolor \MPcolor{\itemgroupparameter{color}};
  draw  (fullsquare scaled height)
             withpen pencircle scaled 0pt withtransparency (1,0) ;
\stopuniqueMPgraphic
\startuniqueMPgraphic{sym:bullet}
  save height , depth ;
  height := \the \bodyfontsize * \currentfontscale ;
  depth  := \the \strutdepth ;
  path bullet;
  bullet := fullcircle scaled .2height;
  fill bullet crossingunder (fullsquare scaled height)
              withpen pencircle scaled 1pt withcolor \MPcolor{\itemgroupparameter{color}};
  draw  (fullsquare scaled height)
             withpen pencircle scaled 0pt withtransparency (1,0) ;
\stopuniqueMPgraphic
\definesymbol [mp:squares]      [{\lower.3ex\vbox{\useMPgraphic{sym:squares-random}}}]
\definesymbol [mp:square]       [{\lower.3ex\vbox{\uniqueMPgraphic{sym:square}}}]
\definesymbol [mp:circle]       [{\lower.3ex\vbox{\uniqueMPgraphic{sym:circle}}}]
\definesymbol [mp:bullet]       [{\lower.3ex\vbox{\uniqueMPgraphic{sym:bullet}}}]

\definesymbol [shadowedsquare]  [{\lower.1\bodyfontsize\hbox{\useMPgraphic{mp:itemgroup:square}}}]
\definesymbol [shadowedcircle]  [{\lower.1\bodyfontsize\hbox{\useMPgraphic{mp:itemgroup:circle}}}]
\definesymbol [shadowedsquares] [{\lower.1\bodyfontsize\hbox{\useMPgraphic{mp:itemgroup:squares}}}]
\definesymbol [shadowedcircles] [{\lower.1\bodyfontsize\hbox{\useMPgraphic{mp:itemgroup:circles}}}]

