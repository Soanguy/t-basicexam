\startmode[moresize]
% show all size customized : o , i , ii ... especially,11pt & 12pt is fixed size
%\noindent\dorecurse{9}{%
%    {\csname tf\romannumeral\recurselevel\endcsname
%     \fontstyle\romannumeral\recurselevel}
