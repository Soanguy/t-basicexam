% \starttextbackground[colorbox]
%   \input knuth
% \stoptextbackground

%D ========== 双栏标题框组件 ==========

\startMPdefinitions
  vardef GetTextWidth(expr textpic) =
    xpart urcorner textpic - xpart llcorner textpic
  enddef;
  
  vardef DrawHeaderBox(expr boxpath, bgcolor, showframe, framecolor, radius, headerh) =
    path resultbox;
    resultbox := boxpath;
    if (radius > 0) :
      resultbox := resultbox cornered min(radius, headerh/3);
    fi;
    fill resultbox withcolor bgcolor;
    if showframe > 0 :
      draw resultbox withcolor framecolor;
    fi;
    resultbox
  enddef;
  
  vardef AlignTextPosition(expr textpic, left, right, align, padding) =
    numeric textw, pos;
    textw := GetTextWidth(textpic);
    if align = 1 :
      pos := left + textw/2 + padding;
    elseif align = 3 :
      pos := right - textw/2 - padding;
    else :
      pos := left + (right - left)/2;
    fi;
    pos
  enddef;
  
  vardef CalcBoxX(expr boxwidth, align, totalwidth, margin) =
    if align = 1 :
      margin
    elseif align = 3 :
      totalwidth - boxwidth - margin
    else :
      (totalwidth - boxwidth) / 2
    fi
  enddef;
  
  def DrawDivider(expr x, top, bottom) =
    draw (x, top) -- (x, bottom);
  enddef;
  
  def DrawDualHeaderFrame(
    expr shownumber, showtitle,
         titlepos, titlealign, numberalign,
         numberbgcolor, titlebgcolor, bodybgcolor, headerbgcolor,
         numbercolor, titlecolor,
         framecolor, numberframecolor, titleframecolor,
         numberframe, titleframe,
         leftframe, rightframe, topframe, bottomframe,
         numberratio, titleratio,
         linethickness, radius,
         bodybackground, shadowcolor,
         symbol, character,
         headerdivider
  ) =
    begingroup;
      numeric w, h, headerh, ox, r;
      path mainframe, numberbox, titlebox, headerbox, divider;
      picture numbertext, titletext;

      w := OverlayWidth;
      h := OverlayHeight;
      headerh := BodyFontSize * 2.2;
      ox := linethickness/2;
      r := radius;

      boolean hasheader;
      hasheader := (shownumber > 0) or (showtitle > 0);

      mainframe := (ox, ox) -- (w-ox, ox) -- (w-ox, h-ox) -- (ox, h-ox) -- cycle;

      if (r > 0) :
        mainframe := mainframe cornered r;
      fi;

      if bodybackground = "shadowbox" :
        numeric shadowthickness;
        shadowthickness := 5 * linethickness;

        numeric shadowtop;
        if (titlepos = 0) and hasheader :
          shadowtop := h - headerh - ox;
        else :
          shadowtop := h - ox;
        fi;

        path myshadow;
        myshadow := (ox, ox) -- (w-ox, ox) -- (w-ox, shadowtop) -- (ox, shadowtop) -- cycle;
        if (r > 0) :
          myshadow := myshadow cornered r;
        fi;
        myshadow := myshadow shifted (shadowthickness/4 * (1,-1));
        
        draw (
          (shadowthickness*right + llcorner myshadow)
          -- lrcorner myshadow
          -- (shadowthickness*down + urcorner myshadow)
        ) withpen pensquare scaled shadowthickness withcolor shadowcolor;
      fi;
      
      drawoptions(withpen pencircle scaled linethickness withcolor framecolor);
      
      path bodyframe;
      if hasheader :
        bodyframe := (ox, ox) -- (w-ox, ox) -- (w-ox, h-headerh-ox) -- (ox, h-headerh-ox) -- cycle;
        if (r > 0) :
          bodyframe := bodyframe cornered r;
        fi;
      else :
        bodyframe := mainframe;
      fi;
      
      if bodybackground = "charbox" :
        fill bodyframe withcolor bodybgcolor;
        if character <> "" :
          draw bodyframe withpattern image (
            draw textext(character) rotated 45
                withcolor framecolor withopacity .2;
          );
        fi;
      elseif bodybackground = "framebox" :
        fill bodyframe withcolor bodybgcolor;
        numeric a;
        a := 2;
        path p;
        p := fullcircle scaled .1a;
        picture patternimage;
        patternimage := image (
          fill p withcolor framecolor withopacity .1;
          fill p shifted (a,-a) withcolor framecolor withopacity .1;
        );
        setbounds patternimage to ((0,0) -- (2a,0) -- (2a,-2a) -- (0,-2a) -- cycle);
        draw bodyframe withpattern patternimage;
      elseif bodybackground = "barbox" :
        fill bodyframe withcolor bodybgcolor;
        if leftframe > 0 :
          path leftbar;
          leftbar := (ox, ox) -- (ox + leftframe*4, ox) -- (ox + leftframe*4, h-ox) -- (ox, h-ox) -- cycle;
          if (r > 0) :
            leftbar := leftbar cornered r;
          fi;
          fill leftbar withcolor framecolor;
        fi;
      else :
        fill bodyframe withcolor bodybgcolor;
      fi;
      
      boolean allframesvisible;
      allframesvisible := (leftframe > 0) and (rightframe > 0) and (topframe > 0) and (bottomframe > 0);
      
      numeric topborderpos;
      if hasheader :
        topborderpos := h - headerh - ox;
      else :
        topborderpos := h - ox;
      fi;
      
      if allframesvisible :
        if (r > 0) :
          if (titlepos = 0) and hasheader :
            draw (ox, ox) -- (ox, topborderpos);
            draw (w-ox, ox) -- (w-ox, topborderpos);
            draw (ox, ox) -- (w-ox, ox);
            draw (ox, topborderpos) -- (w-ox, topborderpos);
          else :
            draw mainframe;
          fi;
        else :
          draw (ox, ox) -- (ox, topborderpos);
          draw (w-ox, ox) -- (w-ox, topborderpos);
          draw (ox, ox) -- (w-ox, ox);
          draw (ox, topborderpos) -- (w-ox, topborderpos);
        fi;
      else :
        if leftframe > 0 :
          draw (ox, ox) -- (ox, topborderpos);
        fi;
        if rightframe > 0 :
          draw (w-ox, ox) -- (w-ox, topborderpos);
        fi;
        if bottomframe > 0 :
          draw (ox, ox) -- (w-ox, ox);
        fi;
      fi;
      
      if hasheader :
        if titlepos = 0 :
          numeric titletop;
          titletop := h - headerh - ox;
          
          if showtitle > 0 :
            if shownumber > 0 :
              numbertext := textext(\MPstring{DualHeaderNumber});
              titletext := textext(\MPstring{DualHeaderTitle});
              
              numeric numberboxwidth, titleboxwidth;
              numberboxwidth := GetTextWidth(numbertext) + 8pt;
              titleboxwidth := GetTextWidth(titletext) + 8pt;
              
              numeric containerwidth, containerx;
              containerwidth := numberboxwidth + titleboxwidth;
              containerx := CalcBoxX(containerwidth, titlealign, w, ox);
              
              numberbox := DrawHeaderBox(
                (containerx, titletop) -- (containerx + numberboxwidth, titletop)
                -- (containerx + numberboxwidth, titletop + headerh) -- (containerx, titletop + headerh) -- cycle,
                numberbgcolor, numberframe, numberframecolor, r, headerh
              );
              
              titlebox := DrawHeaderBox(
                (containerx + numberboxwidth, titletop) -- (containerx + containerwidth, titletop)
                -- (containerx + containerwidth, titletop + headerh) -- (containerx + numberboxwidth, titletop + headerh) -- cycle,
                titlebgcolor, titleframe, titleframecolor, r, headerh
              );

              numbertext := numbertext shifted (containerx + numberboxwidth/2, titletop + headerh/2 - ypart center numbertext);
              draw numbertext withcolor numbercolor;
              
              titletext := titletext shifted (containerx + numberboxwidth + titleboxwidth/2, titletop + headerh/2 - ypart center titletext);
              draw titletext withcolor titlecolor;
              
              if (r = 0) and (headerdivider > 0) :
                DrawDivider(containerx + numberboxwidth, titletop, titletop + headerh);
              fi;
            else :
              titletext := textext(\MPstring{DualHeaderTitle});
              numeric titleboxwidth;
              titleboxwidth := GetTextWidth(titletext) + 8pt;
              
              numeric titlexpos;
              titlexpos := CalcBoxX(titleboxwidth, titlealign, w, ox);
              
              titlebox := DrawHeaderBox(
                (titlexpos, titletop) -- (titlexpos + titleboxwidth, titletop)
                -- (titlexpos + titleboxwidth, titletop + headerh) -- (titlexpos, titletop + headerh) -- cycle,
                framecolor, titleframe, titleframecolor, r, headerh
              );
              
              titletext := titletext shifted (titlexpos + titleboxwidth/2, titletop + headerh/2 - ypart center titletext);
              draw titletext withcolor white;
            fi;
          else :
            if shownumber > 0 :
              numbertext := textext(\MPstring{DualHeaderNumber});
              numeric numberboxwidth;
              numberboxwidth := GetTextWidth(numbertext) + 8pt;

              numeric numberxpos;
              numberxpos := CalcBoxX(numberboxwidth, titlealign, w, ox);
              
              numberbox := DrawHeaderBox(
                (numberxpos, titletop) -- (numberxpos + numberboxwidth, titletop)
                -- (numberxpos + numberboxwidth, titletop + headerh) -- (numberxpos, titletop + headerh) -- cycle,
                numberbgcolor, numberframe, numberframecolor, r, headerh
              );
              
              numbertext := numbertext shifted (numberxpos + numberboxwidth/2, titletop + headerh/2 - ypart center numbertext);
              draw numbertext withcolor numbercolor;
            fi;
          fi;
          if (topframe > 0) :
            draw (ox, topborderpos) -- (w-ox, topborderpos);
          fi;
        else :
          headerbox := (ox, h-headerh) -- (w-ox, h-headerh)
                       -- (w-ox, h-ox) -- (ox, h-ox) -- cycle;
          
          if (r > 0) :
            headerbox := headerbox cornered r;
          fi;
          
          fill headerbox withcolor headerbgcolor;
          
          if shownumber > 0 :
            numeric numberwidth;
            if showtitle > 0 :
              numberwidth := w * numberratio / (numberratio + titleratio);
            else :
              numberwidth := w - 2*ox;
            fi;
            
            numberbox := DrawHeaderBox(
              (ox, h-headerh) -- (numberwidth-ox/2, h-headerh)
              -- (numberwidth-ox/2, h-ox) -- (ox, h-ox) -- cycle,
              numberbgcolor, numberframe, numberframecolor, r, headerh
            );
            
            numbertext := textext(\MPstring{DualHeaderNumber});
            numeric numberxpos;
            numberxpos := AlignTextPosition(numbertext, ox, numberwidth - ox/2, numberalign, 4pt);
            numbertext := numbertext shifted (numberxpos, h - headerh/2 - ypart center numbertext);
            draw numbertext withcolor numbercolor;
          fi;
          
          if showtitle > 0 :
            numeric titleleft;
            if shownumber > 0 :
              titleleft := w * numberratio / (numberratio + titleratio) + ox/2;
            else :
              titleleft := ox;
            fi;
            
            titlebox := DrawHeaderBox(
              (titleleft, h-headerh) -- (w-ox, h-headerh)
              -- (w-ox, h-ox) -- (titleleft, h-ox) -- cycle,
              titlebgcolor, titleframe, titleframecolor, r, headerh
            );
            
            titletext := textext(\MPstring{DualHeaderTitle});
            numeric titlexpos;
            titlexpos := AlignTextPosition(titletext, titleleft, w - ox, titlealign, 4pt);
            titletext := titletext shifted (titlexpos, h - headerh/2 - ypart center titletext);
            draw titletext withcolor titlecolor;
          fi;
          
          if shownumber > 0 :
            if showtitle > 0 :
              if (r = 0) and (headerdivider > 0) :
                numeric dividerpos;
                dividerpos := w * numberratio / (numberratio + titleratio);
                DrawDivider(dividerpos, h-headerh, h-ox);
              fi;
            fi;
          fi;
        fi;
      fi;
      
      if (titlepos = 1) and hasheader and (topframe > 0) :
        draw (ox, topborderpos) -- (w-ox, topborderpos);
      fi;
      
      if bodybackground = "symbolbox" :
        if symbol <> "" :
          picture symtext;
          symtext := textext(symbol);
          symtext := symtext shifted (w - 0.5*BodyFontSize, 0.5*BodyFontSize - 1pt);
          fill bbox symtext withcolor white;
          draw symtext withcolor framecolor;
        fi;
      fi;
      
      setbounds currentpicture to mainframe;
    endgroup;
  enddef;
\stopMPdefinitions

\setMPtext{DualHeaderNumber}{}
\setMPtext{DualHeaderTitle}{}
\setMPtext{DualHeaderNumber}{\hbox spread \baselineskip{\hss\framedtextparameter{number}\hss}}
\setMPtext{DualHeaderTitle} {\hbox spread \baselineskip{\hss\framedtextparameter{title}\hss}}

\startuseMPgraphic{DualHeaderFrame}
  DrawDualHeaderFrame(
    \MPvar{shownumber}, \MPvar{showtitle},
    \MPvar{titlepos}, \MPvar{titlealign}, \MPvar{numberalign},
    \MPvar{numberbgcolor}, \MPvar{titlebgcolor}, \MPvar{bodybgcolor}, \MPvar{headerbgcolor},
    \MPvar{numbercolor}, \MPvar{titlecolor},
    \MPvar{framecolor}, \MPvar{numberframecolor}, \MPvar{titleframecolor},
    \MPvar{numberframe}, \MPvar{titleframe},
    \MPvar{leftframe}, \MPvar{rightframe}, \MPvar{topframe}, \MPvar{bottomframe},
    \MPvar{numberratio}, \MPvar{titleratio},
    \MPvar{linethickness}, \MPvar{radius},
    \MPvar{bodybackground}, \MPvar{shadowcolor},
    \MPvar{symbol}, \MPvar{character},
    \MPvar{headerdivider}
  );
\stopuseMPgraphic

\defineoverlay[DualHeaderBox][\useMPgraphic{DualHeaderFrame}{
