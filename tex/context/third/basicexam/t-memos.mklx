%%%%%%                               zhpinyin                              %%%%%%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\registerctxluafile{m-pinyin}{}

\newdimen\pinyinvsep
\newskip\pinyinhsep
\newskip\pinyinpysep
\newcount\pinyinratio

\pinyinvsep=1em
\pinyinhsep=0pt
\pinyinpysep=\spaceskip
\pinyinratio=4

\def\pinyinpysepstr{\hskip\pinyinpysep}

\installnamespace{pinyin}

\tolerant\def\setuppinyin#*[#S#1]{%
   \getparameters[\????pinyin][#1]%
   \pinyinvsep   =\csname\????pinyin vsep\endcsname
   \pinyinhsep   =\csname\????pinyin hsep\endcsname
   \pinyinpysep  =\csname\????pinyin pysep\endcsname
   \pinyinratio  =\csname\????pinyin ratio\endcsname
   \ctxlua{thirddata.pinyin.setup{%
     multiple=[[\csname\????pinyin multiple\endcsname]],%
     markpolyphone=[[\csname\????pinyin markpolyphone\endcsname]]%
   }}%
 }

\setuppinyin[vsep=0pt,hsep=2pt plus 1pt minus 2pt,pysep=\spaceskip,ratio=6,multiple=no,markpolyphone=no]

\tolerant\def\startpinyinscope#*[#1]%
  {\begingroup
   \doifnotempty{#1}{\setuppinyin[#1]}%
   \grabbufferdata[pinyinscope][pinyinscope][startpinyinscope][stoppinyinscope]}

\def\stoppinyinscope
  {\ctxlua{thirddata.pinyin.process_buffer()}%
   \endgroup}

\tolerant\def\pinyin#*[#S#1]#:#2%
  {\begingroup
   \ifparameters\or\setuppinyin[#1]\fi
   \ctxlua{thirddata.pinyin.format_pinyin_string([==[#2]==])}%
   \endgroup}

\tolerant\def\xpinyin#*[#S#1]#*[#S#2]#:#3%
  {\begingroup
   \ifparameters
     \ctxlua{buffers.assign("xpinyinbuf",[==[#3]==])}%
     \ctxlua{thirddata.pinyin.process_buffer("xpinyinbuf")}%
   \or
     \ifhastok={#1}%
       \setuppinyin[#1]%
       \ctxlua{buffers.assign("xpinyinbuf",[==[#3]==])}%
       \ctxlua{thirddata.pinyin.process_buffer("xpinyinbuf")}%
     \else
       \ctxlua{buffers.assign("xpinyinbuf",[==[#3]==])}%
       \ctxlua{thirddata.pinyin.process_buffer("xpinyinbuf",[==[#1]==])}%
     \fi
   \or
     \setuppinyin[#2]%
     \ctxlua{buffers.assign("xpinyinbuf",[==[#3]==])}%
     \ctxlua{thirddata.pinyin.process_buffer("xpinyinbuf",[==[#1]==])}%
   \fi
   \endgroup}

\def\setpinyin#1#2%
  {\ctxlua{thirddata.pinyin.set(utf.byte([==[#1]==]), [==[#2]==])}}

\newbox\pinyinbox
\newbox\hanzibox

\def\pinyinannotate#1#2#3%
  {\dontleavehmode
   \begingroup
   \setbox\hanzibox\hbox{#1}%
   \setbox\pinyinbox\hbox{%
     \tf
     \doif{#3}{true}{}%
     #2%
   }%
   \dimen1=\wd\pinyinbox
   \multiply\dimen1 by \pinyinratio
   \divide\dimen1 by 10
   \setbox\pinyinbox\hbox{%
     \scale[width=\dimen1]{\box\pinyinbox}%
   }%
   \dp\pinyinbox\z@
   \dimen0=\wd\hanzibox
   \ifdim\wd\pinyinbox>\dimen0
     \dimen0=\wd\pinyinbox
   \fi
   \vbox{%
     \lineskip\z@
     \hbox to \dimen0{\hss\vrule width0pt height0pt depth\pinyinvsep\box\pinyinbox\hss}%
     \nointerlineskip
     \hbox to \dimen0{\hss\strut\box\hanzibox\hss}%
   }%
   \hskip\pinyinhsep\relax
   \endgroup}

