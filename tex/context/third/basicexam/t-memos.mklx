\registerctxluafile{m-zhnumber}{}

\installnamespace {zhnumber}

\installcommandhandler \????zhnumber {zhnumber} \????zhnumber

\setupzhnumber[zero=〇]

\permanent\def\zhnumber{\dosingleempty\dozhnumber}
\def\dozhnumber[#1]#2{\clf_zhnumber{#2}{#1}}

\permanent\def\zhdate#1{\clf_zhdate{#1}}

\permanent\def\zhtime#1{\clf_zhtime{#1}}

\permanent\def\zhweekday#1{\clf_zhweekday{#1}}

\permanent\def\zhtoday{\expanded{\clf_zhdate{\the\normalyear/\the\normalmonth/\the\normalday}}}

\permanent\def\zhcurrtime{\calculatecurrenttime\clf_zhtime{\currenthour:\currentminute}}

\permanent\def\zhtiangan#1{\clf_zhtiangan{#1}}

\permanent\def\zhdizhi#1{\clf_zhdizhi{#1}}

\permanent\def\zhganzhi#1{\clf_zhganzhi{#1}}

\permanent\def\zhganzhinian#1{\clf_zhganzhinian{#1}}

\appendtoks
    \clf_zhsetzero{\zhnumberparameter{zero}}%
\to \everysetupzhnumber

\clf_zhsetzero{\zhnumberparameter{zero}}%

\defineconversion[tiangan][甲, 乙, 丙, 丁, 戊, 己, 庚, 辛, 壬, 癸]

\defineconversion[dizhi][子, 丑, 寅, 卯, 辰, 巳, 午, 未, 申, 酉, 戌, 亥]

\defineconversion[ganzhi]
                 [甲子,乙丑,丙寅,丁卯,戊辰,己巳,庚午,辛未,壬申,癸酉,
                  甲戌,乙亥,丙子,丁丑,戊寅,己卯,庚辰,辛巳,壬午,癸未,
                  甲申,乙酉,丙戌,丁亥,戊子,己丑,庚寅,辛卯,壬辰,癸巳,
                  甲午,乙未,丙申,丁酉,戊戌,己亥,庚子,辛丑,壬寅,癸卯,
                  甲辰,乙巳,丙午,丁未,戊申,己酉,庚戌,辛亥,壬子,癸丑,
                  甲寅,乙卯,丙辰,丁巳,戊午,己未,庚申,辛酉,壬戌,癸亥]

