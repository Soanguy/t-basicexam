%D \section{设置 choice 环境}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\installnamespace          {choice}
\installcommandhandler \????choice    {choice}    \????choice

\appendtoks
  \setuevalue        {\currentchoice}{\directnamedchoice[\currentchoice]}%
  \setuevalue{\e!start\currentchoice}{\startnamedchoice [\currentchoice]}%
  \setuevalue{\e!stop \currentchoice}{\stopnamedchoice}%
\to \everydefinechoice

\setvalue{\??itemgroupkeyword\v!vertical}{\setfalse\c_strc_itemgroups_horizontal
                                          \setfalse\c_strc_itemgroups_collecting
                                          \setfalse\c_strc_itemgroups_inline
                                          \setfalse\c_strc_itemgroups_joined
                                          \strc_itemgroups_process_set_option_unpack}

\tolerant\protected\def\directnamedchoice[#1]#*[#2]#*[#3]#:#4%
{\begingroup
  \def\tempchoicecontent{#4}%
  \startnamedchoice[#1][#2][#3]%
    \ctxlua{thirddata.basicexam.process_choice("tempchoicecontent")}%
  \stopnamedchoice\endgroup}

\startluacode
  local basicexam = thirddata.basicexam

  function basicexam.process_choice(macroname)
    local str = tokens.getters.macro(macroname) or ""
    if str == "" then return end
    
    local function trim(s)
      return s:match("^%s*(.-)%s*$") or s
    end
    
    local function has_content(s)
      if not s or #s == 0 then return false end
      for i = 1, #s do
        local c = s:sub(i, i)
        if c ~= " " and c ~= "\t" and c ~= "\n" and c ~= "\r" then
          return true
        end
      end
      return false
    end
    
    local function strip_braces(s)
      s = trim(s)
      if s:sub(1, 1) == "{" and s:sub(-1, -1) == "}" then
        return s:sub(2, -2)
      end
      return s
    end
    
    local items = {}
    local current = {}
    local brace_depth = 0
    
    for c in str:gmatch(".") do
      if c == "{" then
        brace_depth = brace_depth + 1
        current[#current + 1] = c
      elseif c == "}" then
        brace_depth = brace_depth - 1
        current[#current + 1] = c
      elseif c == "," and brace_depth == 0 then
        local item = table.concat(current)
        if has_content(item) then
          items[#items + 1] = item
        end
        current = {}
      else
        current[#current + 1] = c
      end
    end
    
    local last_item = table.concat(current)
    if has_content(last_item) then
      items[#items + 1] = last_item
    end
    
    local result = {}
    for i = 1, #items do
      local item = items[i]
      local stripped = strip_braces(item)
      local trimmed = trim(stripped)
      
      if trimmed:sub(1, 3) == "[*]" then
        local rest = trim(trimmed:sub(4))
        result[#result + 1] = "\\startcitem[*] " .. rest .. "\\stopcitem"
      else
        result[#result + 1] = "\\startcitem " .. item .. "\\stopcitem"
      end
    end
    
    context(table.concat(result))
  end

  function basicexam.init_choice()
    local tbl_num_temp = {"one","two","three","four","five","six","seven","eight","nine"}
    local tbl_cit_count = tex.count['c_totalchoicenumber']
    local available_columns = tex.count['c_availablecolumns']
    local result
    
    if tbl_cit_count == 3 and available_columns < tbl_cit_count then
      result = "one"
    elseif tbl_cit_count > 1 and available_columns >= tbl_cit_count then
      result = "horizontal," .. tbl_num_temp[tbl_cit_count]
    elseif tbl_cit_count >= 1 and available_columns <= 1 then
      result = "one"
    else
      result = "horizontal,two"
    end
    
    basicexam.available_columns_arg = result
    context(result)
  end

  function basicexam.finalize_choice()
    local a = tex.dimen['d_compared_maxwidth']
    local b = tex.dimen['d_maxwidth_with_label']
    basicexam.currentavailablecolumns = math.floor(a/b)
    context(basicexam.currentavailablecolumns)
  end
\stopluacode

\let\strc_choice_normal_setup\setupchoice

\permanent\overloaded\tolerant\protected\def\setupchoice[#1]#*[#2]{
  \ifarguments\or
    \setupitemgroup[env!choice][#1]
    \strc_choice_normal_setup[#1]
  \or
    \setupitemgroup[env!choice][#1][#2]
    \strc_choice_normal_setup[#1][#2]
  \fi}

\tolerant\protected\def\startnamedchoice[#1]#*[#2]#*[#S#3]#*%
 {\begingroup
  \def\currentchoice{#1}%
  \ifarguments
        \edef\p_option{\choiceparameter\c!option}%
    \or \edef\p_option{\choiceparameter\c!option}%
    \or \ifhastok={#2}%
        \setupcurrentchoice[#2]%
        \edef\p_option{\choiceparameter\c!option}\else
        \edef\p_option{\choiceparameter\c!option,#2}\fi
    \or \ifhastok={#2}%
        \setupcurrentchoice[#2]%
        \edef\p_option{\choiceparameter\c!option}\else
        \edef\p_option{\choiceparameter\c!option,#2}\fi
        \setupcurrentchoice[#3]%
  \fi
  \BasicExamPushLevel\s!choice\s!choice
  \doifelsesomething{\UnlimitedGetExtraData{\UnlimitedCurrentID}{totalitemnumber}}%
     {\scratchcounter\UnlimitedGetExtraData{\UnlimitedCurrentID}{totalitemnumber}}%
     {\scratchcounter\zerocount}%
  \c_totalchoicenumber=\number\scratchcounter\relax
  \doifelsesomething{\UnlimitedGetExtraData{\UnlimitedCurrentID}{availablecolumns}}%
     {\scratchcounter\UnlimitedGetExtraData{\UnlimitedCurrentID}{availablecolumns}}%
     {\scratchcounter\zerocount}%
  \c_availablecolumns=\number\scratchcounter\relax
  \edef\currentrealavailablecolumns{\ctxlua{thirddata.basicexam.init_choice()}}%
  \edef\p_choicetype        {\choiceparameter\c!inlinechoice}%
  \edef\p_correctsymbol     {\choiceparameter{correctsymbol}}%
  \ifx\p_choicetype\s!true
    \edef\p_option{text,\p_option}\else
    \edef\p_option{\currentrealavailablecolumns,\p_option}%
  \fi
  \setup_itemgroup_temp[choice][#2][#3]%
  \choiceparameter\c!inlineleft
  \ifmode_showanswer\else
    \doiftrueelse\s!choice\c!showanswer\mode_showanswertrue\mode_showanswerfalse
  \fi\usechoicestyleandcolor\c!textstyle\c!textcolor}

\protected\def\stopnamedchoice{%
  \removemarkedcontent[inlinechoice_punctuation]%
  \d_maxwidth_with_label = \dimexpr\d_width_cit_max +
                           \d_strc_itemgroups_list_width\relax
  \d_compared_maxwidth   = \choiceparameter{maxiwidth}  \relax% 可排版的最長寬度。
  \def\currentavailablecolumns{\ctxlua{thirddata.basicexam.finalize_choice()}}%
  \def\currentitemmaxwidth    {\the\d_width_cit_max}%
  \UnlimitedSetExtraData{totalitemnumber}{\the\c_currentitemnumber}%
  \UnlimitedSetExtraData{availablecolumns}{\currentavailablecolumns}%
  \UnlimitedSetExtraData{itemmaxwidth}{\currentitemmaxwidth}%
  \edef\currentcollectedanswer{\collectedanswer}
  \edef\currentanswer{%
    \ifempty\currentcollectedanswer
      \ifdefined\currentprevanswer
        \currentprevanswer\fi
    \else\collectedanswer\fi}%
  \ifdefined\currentprevpoint\else
    \def\currentprevpoint{}%
  \fi
  \UnlimitedAddScoredAnswer{\currentanswer}{\currentprevpoint}%
  \choiceparameter\c!inlineright
  \stopitemgroup
  \BasicExamPopLevel
  \endgroup}

\definechoice[choice]
\definechoice[inlinechoice]
\tolerant\def\setupinlinechoice[#1]{\setupchoice[inlinechoice][#1]}

\setupchoice [\c!answerstyle=\ss,
              \c!answercolor=red,
              \c!inlinechoice=false,
              \c!point=\itemgroupparameter\c!point,
              \c!numberconversion=A,
              \c!option={A,packed,joinedup,nowhite,},
                 maxiwidth=.9\hsize,]

\setupinlinechoice[\c!option={text,8,packed,joinedup,nowhite,},
                   \c!inlinechoice=\s!true,
                   correctsymbol={\symbol{marksquarecheck}},
                   inlineleft={ (\nobreak},
                   inlineright={\nobreak ) },
                   %\c!lefttext={},
                   %\c!righttext={},
                   \c!answerstyle=ttx,
                   %\c!stopper=,
                   %\c!showanswer=,% shoule be empty before used
                   \c!separator={\removeunwantedspaces,\space},
                   ]

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%D \section{设置 solution 环境}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\installnamespace {solution}
\installnamespace {solutionalternative}
\installnamespace {solutionrenderings}

\installcommandhandler \????solution            {solution}            \????solution
\installcommandhandler \????solutionalternative {solutionalternative} \????solutionalternative

\appendtoks
    \frozen\instance\protected\edefcsname        \currentsolution\endcsname{\solution_direct_instance}%
    \frozen\protected\instance\edefcsname\e!start\currentsolution\endcsname{\solution_start_instance [\currentsolution]}%
    \frozen\protected\instance\letcsname \e!stop \currentsolution\endcsname \solution_stop_instance
\to \everydefinesolution

\tolerant\protected\def\solution_direct_instance[#S#1]#:#2%
  {\begingroup
  \cdef\currentsolution{#1}%
  \edef\getsolutionbuffer{#2}%
  \doiftrue\s!solution\c!showanswer\mode_showanswertrue
  \doiftrue\s!solution\c!showpoint \mode_showpointtrue
  \doiftrue\s!solution\c!showscript\mode_showscripttrue
  \ifmode_showscript \donetrue\fi
  \ifmode_showanswer \donetrue\fi
  \ifmode_showpoint  \donetrue\fi
  \ifdone
    \solutionparameter\c!before
    \begingroup
    \language[\solutionparameter\c!language]%
    \usesolutionstyleandcolor\c!style\c!color
    \usealignparameter\solutionparameter
    \edef\currentsolutionalternative{\solutionparameter\c!alternative}%
    \ifcsname\currentsolutionalternativehash\s!parent\endcsname \else
      \let\currentsolutionalternative\s!default
    \fi
    \usesetupsparameter\solutionparameter
    \edef\p_renderingsetup{\solutionalternativeparameter\c!renderingsetup}%
    \edef\currentpointforsolution{\currentprevsolutionpoint}%
    \directsetup\p_renderingsetup
    \endgroup
    \solutionparameter\c!after
  \fi
  \xdef\getsolutioncontent{\getsolutionbuffer}%
  \endgroup}

\protected\tolerant\def\solution_start_instance[#S#1]#*[#S#2]#*%
  {\begingroup
  \cdef\currentsolution{#1}%
  \setupcurrentsolution[#2]%
  \grabbufferdatadirect% {\s!solution:\currentsolution}%
    {\s!solution}% unnested, as before
    {\e!start\currentsolution}%
    {\e!stop \currentsolution}}

\permanent\protected\def\solution_stop_instance{%
  \doiftrue\s!solution\c!showanswer\mode_showanswertrue
  \doiftrue\s!solution\c!showpoint \mode_showpointtrue
  \doiftrue\s!solution\c!showscript\mode_showscripttrue
  \ifmode_showscript\donetrue\fi
  \ifmode_showanswer\donetrue\fi
  \ifmode_showpoint \donetrue\fi
  \ifdone
    \leftskip0pt\relax\rightskip\leftskip\relax
    \solutionparameter\c!before
    \begingroup
    \language[\solutionparameter\c!language]%
    \usesolutionstyleandcolor\c!style\c!color
    \usealignparameter\solutionparameter
    \edef\currentsolutionalternative{\solutionparameter\c!alternative}%
    \ifcsname\currentsolutionalternativehash\s!parent\endcsname \else
      \let\currentsolutionalternative\s!default
    \fi
    \usesetupsparameter\solutionparameter
    \edef\p_renderingsetup{\solutionalternativeparameter\c!renderingsetup}%
    \edef\currentpointforsolution{\currentprevsolutionpoint}%
    \directsetup\p_renderingsetup
    \endgroup
    \xdef\getsolutioncontent{\getsolutionbuffer}
    \solutionparameter\c!after
  \fi
  \endgroup}

\tolerant\protected\def\getsolutionbuffer      [#1]{\getbufferdata[\s!solution]}
\tolerant\protected\def\getinlinesolutionbuffer[#1]{\inlinebuffer [\s!solution]}

\definesolutionalternative
  [\s!default]
  [\c!renderingsetup=\????solutionrenderings:\s!default]

\definesolutionalternative
  [\s!none]
  [\c!renderingsetup=\????solutionrenderings:\s!none]

\startsetups[\????solutionrenderings:\s!none]
\stopsetups

\startsetups[\????solutionrenderings:\s!default]
  \starttextbackground[env!solution]
  \ifenv_material% 可以用来做文章翻译或内容解释，
    \ifmode_showanswer
      \getsolutionbuffer% 也可以直接放置在文章之后，或这每一个段落之后
    \fi
  \else
    \ifmode_showscript
        \solutionparameter{scriptcontent}%
    \else
      \noindent
      \showpointoranswer[solution][answer]%
      \showpointoranswer[solution][point]%
      \solutionparameter\c!inbetween
      \getsolutionbuffer
    \fi
  \fi
  \stoptextbackground
\stopsetups

\tolerant\protected\def\startoldsolution[#1]#:#2\stopoldsolution%
{\begingroup
  \lettonothing\getsolutionbuffer
  \lettonothing\getinlinesolutionbuffer
  \cdef\currentsolution{#1}%
  \setupcurrentsolution[#2]%
  \edef\getsolutionbuffer{#2}%
  \usesetupsparameter\solutionparameter
  \edef\p_renderingsetup{\solutionalternativeparameter\c!renderingsetup}%
  \directsetup\p_renderingsetup
  \tolerant\protected\xdef\getsolutioncontent[##1]% only for writing env
    {#2}%%
  \endgroup}

\setupsolution
  [\c!answerlabel={{\examtexts{answer}}},
  \c!pointlabel={,\examtexts{point}},
  \c!pointstyle=\solutionparameter\c!style,
  \c!pointcolor=\solutionparameter\c!color,
  \c!answerstyle=\solutionparameter\c!style,
  \c!answercolor=\solutionparameter\c!color,
  \c!style=\ss\it,
  \c!before=\blank[halfline]\startnarrower,
  \c!after=\blank[halfline]\stopnarrower,
  % \c!align=,
  \c!inbetween={\par},
  %\c!showscript=true,
  scriptcontent={\noindent\ssx\gray Write solution Here},
  \c!alternative=\s!default,
  \c!language=\currentlanguage,
  ]

\definesolution[solution]
\definesolution[answer]
\def\setupanswer{\setupsolution[answer]}

\setuptextbackground[env!solution]%
  [location=paragraph,width=local,
  leftoffset=1ex,rightoffset=1ex,
  before=,after=,\c!frame=on,
  %topoffset=.5ex,bottomoffset=.5ex,
  %\c!framecolor=,
  %\c!rulethickness=,
  state=start,
  corner=round,
  background=color,backgroundcolor=transparentcolor,
  rulethickness=1pt]

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%D \section{设置 pitem,citem 命令}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\installnamespace          {examitem}
\installcommandhandler \????examitem     {examitem}     \????examitem

\defineexamitem[pitem]
\def\setuppitem{\setupexamitem[pitem]}

\setuppitem    [%showpoint=,
                %point=,
                pointstyle=\ttx,
                %pointcolor=,
                pointlabel={,\examtexts{point}},
                answerlabel={\examtexts{answer},},
                %showanswer=,
                %answer=,
                answerstyle=ttx,
                %answerstyle=,
                %reference=,
                ]

\tolerant\protected\def\startpitem#*[#1]%
{\begingroup
    \edef\currentexamitem{pitem}%
    \iffirstargument\setuppitem[#1]\fi%
    \startitem[\namedexamitemparameter\currentexamitem\c!reference]%
      \BasicExamPushLevel\s!examitem\currentexamitem
      \useexamitemstyleandcolor\c!textstyle\c!textcolor
}

\def\stoppitem{\BasicExamPopLevel\stopitem\endgroup}

%D [*](用于标记正确答案)

\defineexamitem[citem]
\def\setupcitem{\setupexamitem[citem]}

\def\c!fullline{fullline}

\setupcitem[fullline=no,]

\newconditional\c_choice_item_fullline
\newconditional\c_strc_itemgroups_item_fullline

\installcorenamespace{itemgroupfullline}

\def\strc_itemgroups_collected_store#1\stopitem
  {\advanceby\c_strc_itemgroups_collected_stored\plusone
   \defcsname\??itemgroupstack\the\c_strc_itemgroups_collected_stored\endcsname
     {\startitemgroupitem#1\stopitemgroupitem}%
   \ifconditional\c_strc_itemgroups_item_fullline
     \defcsname\??itemgroupfullline\the\c_strc_itemgroups_collected_stored\endcsname{1}%
   \else
     \defcsname\??itemgroupfullline\the\c_strc_itemgroups_collected_stored\endcsname{0}%
   \fi
   \c_strc_itemgroups_item_fullline\conditionalfalse}

\def\strc_itemgroups_collected_flush_horizontal
  {\begingroup
   \scratchcounter\itemgroupparameter\c!n\relax
   \ifcsname\??itemgroupfullline\the\c_strc_itemgroups_collected_current\endcsname
     \edef\m_fullline{\csname\??itemgroupfullline\the\c_strc_itemgroups_collected_current\endcsname}%
   \else
     \def\m_fullline{0}%
   \fi
   \ifnum\numexpr\m_fullline=1\relax
     \par\noindent\m_strc_itemgroups_collected\par
   \else
     \ifnum\numexpr\c_strc_itemgroups_collected_done>\plusone\relax
       \ifcase\modulonumber\scratchcounter\c_strc_itemgroups_collected_done\relax
         \hfill\allowbreak
       \fi
     \fi
     \noindent
     \hbox to {\availablehsize/\scratchcounter}{\m_strc_itemgroups_collected\hss}%
   \fi
   \endgroup}

\edef\applychoicestyleandcolor{%
  \ifempty\p_answerstyle
        \dousestyleparameter{\itemgroupparameter\c!answerstyle}%
  \else \dousestyleparameter{\choiceparameter   \c!answerstyle}\fi
  \ifempty\p_answercolor
        \dousecolorparameter{\itemgroupparameter\c!answercolor}%
  \else \dousecolorparameter{\choiceparameter   \c!answercolor}\fi
}

\protected\def\check_correct_choice#1#2{%
  \useexamitemstyleandcolor\c!textstyle\c!textcolor
  \edef\p_correctmark_m{*}\edef\p_correctmark_p{#1}%
  \edef\p_answerstyle{\choiceparameter\c!answerstyle}%
  \edef\p_answercolor{\choiceparameter\c!answercolor}%
  \ifx\p_choicetype\s!true% if inlinechoice
    \ifx\p_correctmark_p\p_correctmark_m
      \ifx\p_correctsymbol\c!default
        \startitem[\namedexamitemparameter{citem}\c!reference]%
          \bgroup
          \ifmode_showanswer\applychoicestyleandcolor\fi
          #2\collectanswer{#2}%
          \egroup
        \stopitem
      \else
        \bgroup
        \ifmode_showanswer\applychoicestyleandcolor
          \sym{\ifempty\p_correctsymbol\symbol{marksquarecheck}\else
                      \p_correctsymbol\fi}% correct inline choice
        \fi
        #2\collectanswer{#2}%
        \egroup
      \fi
    \else
      \startitem[\namedexamitemparameter{citem}\c!reference]#2\stopitem
    \fi
  \else% 如果不是 inlinechoice
    \ifx\p_correctmark_p\p_correctmark_m% 如果标记正确答案
      \startitem[\namedexamitemparameter{citem}\c!reference]%
        \bgroup
          \ifmode_showanswer\applychoicestyleandcolor\fi
          #2
        \egroup
      \stopitem
      \edef\currentanswerindex{\the\c_currentitemnumber}%
      \edef\correct_choice_index{\convertnumber{\choiceparameter\c!numberconversion}{\currentanswerindex}}%
      \collectanswer{\correct_choice_index}% collect current normal answer
    \else% 必须分离已标记和未标记的答案，来进行正确的样式设置
      \startitem[\namedexamitemparameter{citem}\c!reference]#2\stopitem
    \fi%
  \fi
  \ifx\p_choicetype\s!true
    \markcontent[inlinechoice_punctuation]{\choiceparameter\c!separator}%
  \fi}

\protected\def\get_citem_text[#1]{\setbox0=\hbox{#1}%
    \d_width_cit = \the\wd0\relax%relax is neccessary
    \ifdim \d_width_cit_max > \d_width_cit%
           \d_width_cit_max = \d_width_cit_max%
    \else  \d_width_cit_max = \d_width_cit%
    \fi}%%%% 遞歸計算出最大寬度

\tolerant\protected\def\startcitem[#S#1]#spacer[#S#2]#:#3\stopcitem{%
  \edef\currentexaminfo{citem}%
  \edef\currentexamitem{citem}%
  \c_strc_itemgroups_item_fullline\conditionalfalse
  \edef\p_correctmark_p{}\edef\p_correctmark_m{*}%
  \ifparameter#1\or
    \ifhastok={#1}%
      \setupcurrentexamitem[#1]%
      \doiftrue\s!examitem\c!fullline{\c_strc_itemgroups_item_fullline\conditionaltrue}%
    \else
      \edef\p_correctmark_p{#1}%
    \fi
  \fi
  \ifparameter#2\or
    \setupcurrentexamitem[#2]%
    \doiftrue\s!examitem\c!fullline{\c_strc_itemgroups_item_fullline\conditionaltrue}%
  \fi
  \get_citem_text[{#3}]%
  \global\advance\c_currentitemnumber by 1\relax
  \check_correct_choice{\p_correctmark_p}{#3}%
  \removeunwantedspaces
  \lettonothing\currentexaminfo}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%D \section{定义同义命令}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\def\pitem{\dosingleempty\pitem_indeed}
\def\pitem_indeed[#1]#2{
  \startpitem[#1]{#2}\stoppitem}

\def\citem{\dodoubleempty\citem_indeed}
\def\citem_indeed[#1][#2]#3{%
  \ifparameter#1\or
    \ifparameter#2\or
      \startcitem[#1][#2]{#3}\stopcitem
    \else
      \startcitem[#1]{#3}\stopcitem
    \fi
  \else
    \startcitem{#3}\stopcitem
  \fi}

%D 谨慎使用下面的 fragilecitem，他并不安全。很有可能导致错误

\bgroup
\obeylines
\gdef\xcitem{\bgroup\obeylines\dosingleempty\doxcitem}%
\gdef\doxcitem[#1]#2
  {\egroup%
  \doifsomethingelse{#1}%
  {\startcitem[*]#2\stopcitem}%
  {\startcitem #2\stopcitem}%
  }%
\egroup

\let\fragilecitem\xcitem

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%D \section{設置 fillin 命令}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

%D The command is recommended to be used within the pitem environment.
%D Of course, since pitem itself also has an answer key, it can be set through this key.
%D
%D The fillin command mainly relies on the bar command.
%D Basically, modifying the bar command can modify the fillin command.
%D The fillin command has two parameters that refer to textnote: empty and n.
%D empty=yes hides the answer; empty=number shows the number and hides the answer; empty=none shows the answer.
%D n=* hides the answer, with a length equal to the answer length; n=NUMBER controls the length of the bar.

%D There are four main styles of bar, which can be set by mp parameters:
%D rules:under:dots    %rules:under:random
%D rules:under:dash    %rules:under:wave

%D 新增一个 align=autoright 来让 fillin 对齐右方。

\installnamespace {fillin}
\installnamespace {fillinalternative}
\installnamespace {fillinrenderings}

\installframedcommandhandler\????fillin            {fillin}            \????fillin
\installcommandhandler      \????fillinalternative {fillinalternative} \????fillinalternative

\appendtoks
  \frozen\instance\protected\edefcsname \currentfillin\endcsname{\directnamedfillin[\currentfillin]}%
\to \everydefinefillin

\setupfillin[%foregroundcolor=,
             %before=,after=,
             %left=,right=,
             %repeat=,mp=
              alternative=default,
              rule=FillinText,% 引用 bar 命令
              empty=yes,
              continue=yes,
              unit=em,
              order=foreground,
              method=0,
              %color=gray,
              width=4em,
              n=4,
              dy=-0.35,
              max=3,
              offset=-.1,
              rulethickness=.5pt,
              style=\ss,]

% \setupfillin[width=fit,offset=0pt,location=low] %if alternative=framed

\tolerant\protected\def\directnamedfillin[#1]#*[#2]#:#3{%
  \begingroup
    \edef\currentfillin{#1}%
    \ifparameters\or\or\setupcurrentfillin[#2]\or\setupfillin[#2]\fi
    \global\advance\c_fillinnumber by 1\relax
    \def\currentfillinanswer%
     {\usefillinstyleandcolor\c!answerstyle\c!answercolor
      \toks0={#3}\ifempty\toks0 \UnlimitedCurrentAnswer
        \ifdefined\currentprevanswer\currentprevanswer\fi
      \else #3\fi}% 如果 #3 为空，就使用前一個答案
    \edef\p_number{\number\c_fillinnumber}%
    \edef\p_align{\fillinparameter\c!align}%
    \edef\currentfillinalternative{\fillinparameter\c!alternative}%
    \ifcsname\currentfillinalternativehash\s!parent\endcsname\else
      \let\currentfillinalternative\s!default
    \fi
    \usesetupsparameter\fillinparameter
    \edef\p_renderingsetup{\fillinalternativeparameter\c!renderingsetup}%
    \unskip
    \doifinset{\c!autoright}{\p_align}%
      {\nobreak\hfill\penalty50\null\nobreak\hfill}%
      {\allowbreak}%
    \usefillinstyleandcolor\c!style\c!color
    \fillinparameter\c!before
    \fillinparameter\c!left
    \directsetup\p_renderingsetup
    \fillinparameter\c!right
    \fillinparameter\c!after
    \doifinset{\c!autoright}{\p_align}%
      {\parfillskip=0pt \finalhyphendemerits=0 \par}%
      {\allowbreak}%
    \edef\currentanswer      {#3\collectanswer{#3}}%
    \toks0={#3}%
    \ifempty\toks0
         \edef\currentanswer{\currentprevanswer}% 讓 fillin 繼承 前一個答案
    \else\edef\currentanswer{\collectedanswer}%
    \fi\xdef\currentprevanswer{\currentanswer}%
  \ifdefined\currentpoint \relax\else\let\currentpoint\empty\fi
  \UnlimitedAddScoredAnswer{\currentanswer}{\currentpoint}%
  \endgroup
}

\definefillinalternative
  [\s!default]
  [\c!renderingsetup=\????fillinrenderings:\s!default]

\definefillinalternative
  [\c!frame]
  [\c!renderingsetup=\????fillinrenderings:\c!frame]

\definefillinalternative
  [simple]
  [\c!renderingsetup=\????fillinrenderings:simple]

\startsetups[\????fillinrenderings:\s!default]
  \edef\currentbar{\fillinparameter\c!rule}%
  \ifmode_showanswer\setfillinparameter{empty}{none}\fi
  \edef\p_empty{\fillinparameter\c!empty}%
  \edef\p_n{\fillinparameter\c!n}%
  \def\currentfillincontent%
    {\ifchknum\p_n\or
      \scratchcounterone\numexpr\p_n/2\relax
      \interwordspacesbefore\scratchcounterone
      \ifx\p_empty\v!yes    \fi
      \ifx\p_empty\v!number \zwnj\runninghbox{\resetbar\p_number}\zwnj\fi
      \ifx\p_empty\v!none   \currentfillinanswer\fi
      \interwordspacesafter \scratchcounterone
    \fi}
  \start
    \dontleavehmode
    \overloaded\let\barparameter\fillinparameter
    \node_rules_set\currentbar{\currentfillincontent}%
  \stop
\stopsetups

\startsetups[\????fillinrenderings:\c!frame]
  \edef\p_empty{\fillinparameter\c!empty}%
  \def\currentfillincontent{%
    \ifx\p_empty\v!yes   \fi
    \ifx\p_empty\v!number\p_number\fi
    \ifx\p_empty\v!none  \currentfillinanswer\fi}%
  \inheritedfillinframed\bgroup
      \currentfillincontent
  \egroup
\stopsetups

\startsetups[\????fillinrenderings:simple]
  \ifmode_showanswer
    \currentfillinanswer
  \else
    \leavevmode\leaders\hrule height 1pt\hfill\kern0pt
  \fi
\stopsetups

\definefillin[fillin]
\definefillin[fillinframe]  [alternative=frame,offset=0pt,location=low,left=\thinspace,right=\thinspace,align={lohi,center}]
\definefillin[fillinbracket][fillinframe][left=(,right=),align={center,autoright},framecolor=transparentcolor,style=,]

\startuseMPgraphic{rules:under:wave}
  vardef lsin primary x =
      lua("mp.print(math.sin(" & decimal x & "))")
  enddef ;
  draw function(1, "x", "lsin(1.2*x)", 0, RuleWidth, .1pt)
        shifted (0,RuleFactor*RuleOffset+RuleDepth)
        withpen pencircle scaled RuleThickness
        withcolor RuleColor ;
  setbounds currentpicture to unitsquare xysized(RuleWidth,RuleHeight) ;
\stopuseMPgraphic
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%D \section{設置 material 環境}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

%D 顧名思義，\tex{material} 環境用來放置大段文本材料。
%D 該環境比較特殊，它設置了多個子實例來進行更完善的設置。
%D 除了 \tex{setupmaterial[number]} 這個實例繼承了 \tex{setupcounter} 的全部鍵值之外，
%D 其他實例都是新定義的鍵值。

%D 這些實例分別是：
%D \startitemize[nowhite,joinedup,packed]
%D \item \tex{setupmaterial[number]}    設置 該環境標題的 {\bf 序號};
%D \item \tex{setupmaterial[title]}     設置 該環境的 {\bf 標題} 相關的樣式;
%D \item \tex{setupmaterial[author]}    設置 該環境文章的 {\bf 作者} 相關的樣式;
%D \item \tex{setupmaterial[source]}    設置 該環境文章的 {\bf 具體來源} 的相關樣式。
%D \item \tex{setupmaterial[indicator]} 設置 該環境文章的 {\bf 畫線序號文字} 的相關樣式。
%D \stopitemize

%D 此外，\type{title},\type{author},\type{source} 的名稱是通過 \tex{setupmaterial}
%D 來直接設置。此外， 該環境具有一個特殊的子命令 \tex{indicator} 來標記文章中的提問的部分並
%D 進行添加數字標識 --- （一）畫線文字。因此，\tex{setupmaterial} 還具有一個鍵值 indicator
%D 通過 \type{indicator=reset} 對 indicator 進行重置，每當開啓一個新的 material 環境。
%D 通過 \type{indicator=continue} 對 indicator 取消重置，它將持續計數。
%D 當然，也可以直接通過 \tex{setupmaterial[indicator][reset=true]} 來啓用重新計數

%D 以上所有實例都具有以下鍵值：
%D before after align style color
%D 此外，\tex{setupmaterial} 可以通过 spacebefore 和spaceafter 来控制环境前后的垂直距离

%D notice , if you want change [start = number] after a chapter ,
%D you should use \tex{resetcount[COUNTER_NAME]} to reset current counter
%D to the number of start you've setted.
%D otherwise, you need put [start = number] before the chapter you want
%D to reset the counter.

\installnamespace          {material}
\installcommandhandler \????material  {material}  \????material
\installcounterassociation {material}

\appendtoks
   \registermaterialcounter{material:\currentmaterial}
   \definecounter[material:\currentmaterial]%
\to \everydefinematerial

\appendtoks
   \synchronizematerialcounters
\to \everysetupmaterial

\definematerial [material]
\definematerial [number]
\definematerial [indicator]
\definematerial [indicator_helper][indicator]

\setupmaterial [\c!align=center,
                %\c!color=,
                %\c!style=,
                \c!spacebefore=1em,
                \c!spaceafter=1em,
                \s!number=true,
                %\c!title=,
                %\c!author=,
                %\c!source=,
                \c!indicator=continue,
                indenting={first,always,2em},]
\setupmaterial [\c!number] [\c!before={(},\c!after={)},
                            \c!prefix=no,\c!start=0,
                            \c!style=\namedmaterialparameter\c!title\c!style,
                            \c!color=\namedmaterialparameter\c!title\c!color,
                            \c!numberconversion=cn,\c!way=\v!by\v!chapter]
\setupmaterial [\c!title]  [\c!style=\ss\tfa,\c!color=,\c!align=center,
                            \c!before=,]
\setupmaterial [\c!author] [\c!style=\tf,\c!color=,\c!align=flushright]
\setupmaterial [\c!source] [\c!before=\par,\c!align=flushright]
\setupmaterial [indicator,indicator_helper]
               [\c!style=\ssbf,
                \c!color=,
                \c!before={\;(\nobreak\,\nobreak},
                \c!after={\nobreak\,\nobreak)\;},
                \c!prefix=no,
                \c!numberconversion=cn,
                \c!type=line,
                \c!reset=false,
                \c!method=0,% below is for bar setting
                \c!continue=\v!yes,
                \c!empty=,
                \c!offset=-0.3,
                \c!dy=-0.35,
                \c!max=3,
                \c!rulethickness=.1,
                \c!order=\v!foreground,
                \c!unit=ex,]

\def\material_counter_parameter#1%
  {\begingroup
    \def\currentmaterial{#1}%
    \setupalign[\namedmaterialparameter\c!title\c!align]%
    \usematerialstyleandcolor\c!style\c!color
    \namedmaterialparameter\currentmaterial\c!before
    \incrementcounter[material:#1]\convertedcounter[material:#1]%
    \namedmaterialparameter\currentmaterial\c!after
   \endgroup}

\def\material_parameter#1%creat new element in material
  {{\begingroup
    \def\currentmaterial{#1}%
    \setupalign[\namedmaterialparameter\currentmaterial\c!align]%
    \usematerialstyleandcolor\c!style\c!color
    \namedmaterialparameter\currentmaterial\c!before
    \expandafter\doifemptyelse\expandafter{\rootmaterialparameter\currentmaterial}%
    {\rootmaterialparameter\currentmaterial}%
    {\namedmaterialparameter{material}\currentmaterial}%
    \namedmaterialparameter\currentmaterial\c!after
    \par\endgroup}}

\tolerant\protected\def\startmaterial[#1]#*{\begingroup%
  \lettonothing\currentmaterial%%
  \edef\currentmaterial{material}%
  \iffirstargument\setupcurrentmaterial[#1]\fi
  \edef\p_number{\rootmaterialparameter\c!number}%
  \edef\p_indicator{\rootmaterialparameter\c!indicator}%
  \edef\p_reset{\namedmaterialparameter{indicator}\c!reset}%
  \processaction[\p_indicator][
    reset=>\let\indicator_reset_helper\resetindicators,
  continue=>\continue_countertrue\let\indicator_reset_helper\relax,]%
  \processaction[\p_reset][
    true=>\let\indicator_reset_helper\resetindicators,
    false=>\continue_countertrue\let\indicator_reset_helper\relax,]%
  \indicator_reset_helper
  \usematerialstyleandcolor\c!style\c!color%
  \rootmaterialparameter\c!before
  \blank[\rootmaterialparameter\c!spacebefore]%
  \startalignment[\rootmaterialparameter\c!align]%
    \ifx\p_number\s!true
      \material_counter_parameter\c!number
    \fi
    \material_parameter\c!title
    \material_parameter\c!author
  \stopalignment
  \blank[\rootmaterialparameter\c!spaceafter]%
  \setupindenting[\rootmaterialparameter{indent}]%
  \penalty 10000\relax}

\def\stopmaterial{%
    \material_parameter\c!source
    \rootmaterialparameter\c!after
    \indicator_reset_helper
    \endgroup}

\tolerant\protected\def\indicator[#1]#:#2%
  {\begingroup\def\currentmaterial{indicator}%
  \setupmaterial[\currentmaterial][#1]%
  \edef\indicator_type{\namedmaterialparameter\currentmaterial\c!type}%
  \edef\indicator_reset{\namedmaterialparameter\currentmaterial\c!reset}%
  \overloaded\def\barparameter{\namedmaterialparameter\currentmaterial}%
  \iftok{\indicator_type}{line}\let\indicator_type\underbar
    \else\let\indicator_type\relax\fi
  \usematerialstyleandcolor\c!style\c!color%
  \indicator_type\bgroup
  \namedmaterialparameter\currentmaterial\c!before%
  \ifenv_material
    \incrementcounter[material:\currentmaterial]%
    \convertedcounter[material:\currentmaterial]%
  \else
    \incrementcounter[material:indicator_helper]%
    \convertedcounter[material:indicator_helper]%
  \fi
  \namedmaterialparameter\currentmaterial\c!after
  \penalty0\relax
    #2\egroup
  \endgroup}

\tolerant\protected\def\copycurrentindicator[#1]#:#2%
  {\begingroup\def\currentmaterial{indicator}%
  \setupmaterial[\currentmaterial][#1]%
  \edef\indicator_type{\namedmaterialparameter\currentmaterial\c!type}%
  \edef\indicator_reset{\namedmaterialparameter\currentmaterial\c!reset}%
  \overloaded\def\barparameter{\namedmaterialparameter\currentmaterial}%
  \iftok{\indicator_type}{line}\let\indicator_type\underbar
    \else\let\indicator_type\relax\fi
  \usematerialstyleandcolor\c!style\c!color%
  \indicator_type\bgroup
  \namedmaterialparameter\currentmaterial\c!before%
  \ifenv_material\convertedcounter[material:\currentmaterial]%
  \else          \convertedcounter[material:indicator_helper]\fi
  \namedmaterialparameter\currentmaterial\c!after
  \penalty0\relax
    #2\egroup
  \endgroup}

\def\indicators{%%% TODO 增強該命令的用法
  \ifenv_material
    \incrementcounter[material:indicator]%
    \convertedcounter[material:indicator]%
  \else
    \incrementcounter[material:indicator_helper]%
    \convertedcounter[material:indicator_helper]%
  \fi}
\def\resetindicators{\setcounter[material:indicator][0]%
                     \setcounter[material:indicator_helper] [0]}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%D \section{Chinese Verse}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\installnamespace          {verse}
\installcommandhandler \????verse            {verse}            \????verse
\def\c!verse{verse}
\def\c!skip{skip}

\defineverse[\c!title]
\defineverse[\c!author]
\setupverse            [%title=,author=,source={KKK},skip=both,
                        \c!sample={一二三四五六七}, \c!skip=\v!left]
\setupverse [\c!title] [\c!align=center,    \c!style=bf,\c!skip=\v!both,\c!before=,\c!after=]
\setupverse [\c!author][\c!align=flushright,\c!style=it,\c!skip=\v!both,\c!before=,\c!after=]
\setupverse [\c!source][\c!align=flushright,\c!style=it,\c!skip=\v!both,\c!before=,\c!after=]

\newdimen\d_temp_leftskip
\def\c_verse_skip{%
 \ifx\verse_skip\v!left\leftskip\d_temp_leftskip\relax\fi
 \ifx\verse_skip\v!right\rightskip\d_temp_leftskip\relax\fi
 \ifx\verse_skip\v!both
   \leftskip\d_temp_leftskip\relax
   \rightskip\leftskip\relax
 \fi}

\def\verse_element#1%
  {\begingroup%
  \edef\currentverse{#1}%
  \edef\verse_skip{\namedverseparameter\currentverse\c!skip}%
  \c_verse_skip
  \namedverseparameter\currentverse\c!before
  \startalignment[\namedverseparameter\currentverse\c!align]
  \useversestyleandcolor\c!style\c!color
  \rootverseparameter\currentverse
  \stopalignment
  \namedverseparameter\currentverse\c!after
  \endgroup}

\tolerant\protected\def\startverse[#1]#*%
  {\begingroup\parindent0pt\relax\let\\\par
  \iffirstargument\setupverse[#1]\fi
  \edef\verse_skip{\verseparameter\c!skip}%
  \setwidthof{\verseparameter\c!sample}\to\d_temp_maxwidth
  \d_temp_leftskip=\dimexpr.5\textwidth-.5\d_temp_maxwidth\relax
  \ifx\verse_skip\v!none\relax\else
    \c_verse_skip
  \fi
  \verseparameter\c!before
  \verse_element \c!title
  \verse_element \c!author
  \useversestyleandcolor\c!style\c!color
  \ifx\verse_skip\v!none
  \startalignment[\verseparameter\c!align]\fi}

\def\stopverse{\par\ifx\verse_skip\v!none\stopalignment\fi
  \leftskip0pt\rightskip\leftskip\relax
  \verse_element\c!source\verseparameter\c!after\endgroup}

% \setupverse [\c!sample={滾滾長江東逝水浪花淘盡英雄},\c!skip=\v!left,before=\blank,after=\blank]
% \setupverse [\c!title] [\c!align=center,\c!style=bf,\c!skip=\v!both]
% \setupverse [\c!author][\c!align=flushright,\c!style=it,\c!skip=\v!both]
% \setupverse [\c!source][\c!align=flushright,\c!style=it,\c!skip=\v!both]

% \startbuffer
% \startverse[title=临江仙 $\cdot$ 滚滚长江东逝水,author=明 $\cdot$ 杨慎]
% 滾滾長江東逝水浪花淘盡英雄\\
% 是非成敗轉頭空\\
% 青山依舊在 幾度夕陽紅\\
% 白髮漁樵江渚上 慣看秋月春風\\
% 一壺濁酒喜相逢\\
% 古今多少事 都付笑談中
% \stopverse
% \stopbuffer

% \getbuffer

% \setupverse[skip=none,align=center]
% \getbuffer

% \setupverse [\c!sample={\rma\bf滾滾長江東逝水浪花淘盡英雄},\c!skip=\v!left,style=\rma\bf]
% \setupverse [\c!title] [style=ssa]
