\tolerant\protected\def\showpointoranswer[#1]#*[#2]%
 {\edef\currentmode{#2}% check point or answer
  \overloaded\expandafter\let\expandafter\p_currentparameter\csname #1parameter\endcsname%
  \edef\p_totalpoint {\p_currentparameter{totalpoint}}%
  \edef\p_totalanswer{\p_currentparameter{totalanswer}}%
  \ifx\currentmode\c!answer
    \ifempty{\p_currentparameter\c!showanswer}\else
      \doiftrueelse{#1}\c!showanswer\mode_showanswertrue\mode_showanswerfalse
    \fi
    \ifempty{\p_currentparameter\c!showscript}\else
      \doiftrueelse{#1}\c!showscript\mode_showscripttrue\mode_showscriptfalse
    \fi
    \ifmode_showanswer\mode_showscriptfalse\fi
    \ifmode_showscript\mode_showanswerfalse\fi
  \else
    \ifempty{\p_currentparameter\c!showpoint}\else
      \doiftrueelse{#1}\c!showpoint\mode_showpointtrue\mode_showpointfalse
    \fi
  \fi
  \ifempty{\p_currentparameter{showmore}}\else
    \doiftrueelse{#1}{showmore}\mode_showmoretrue\mode_showmorefalse
  \fi
  \edef\currentpoint{%
    \ifempty{\p_currentparameter\c!point}
      \ifdefined\currentprevpoint\currentprevpoint\fi
    \else\p_currentparameter\c!point\fi}%
  \edef\currentanswer{\p_currentparameter\c!answer}%
  \begingroup
    \expandafter\edef\csname p_current#1#2label\endcsname{\p_currentparameter{#2label}}%
    \expandafter\expandafter
      \expandafter\p_pass_currentlabel
        \expandafter\expandafter
          \expandafter[\csname p_current#1#2label\endcsname]{#2}%
    \csname ifmode_show#2\endcsname
      \dousestyleparameter    {\p_currentparameter{#2style}}%
      \dousecolorparameter    {\p_currentparameter{#2color}}%
      \csname\e!start #1examinfo\endcsname
        \left_assignedlabel
          \ifx\currentmode\c!point% if #2 = point
            \iftok{#1}{solution}
              \currentpointforsolution
            \else
              \ifempty\currentpoint\p_totalpoint
                \else\UnlimitedCurrentPoint\fi
            \fi
          \else% if #2 = answer
            \iftok{#1}{solution}
              \currentprevsolutionanswer
            \else
              \ifempty\p_totalanswer
                \ifempty\currentanswer
                  \UnlimitedCurrentAnswer
                \else
                  \currentanswer
                \fi
              \else
                \p_totalanswer
              \fi
            \fi
          \fi
        \right_assignedlabel
      \csname\e!stop #1examinfo\endcsname
    \fi
    \xdef\currentprevsolutionpoint{\UnlimitedCurrentPoint}%
    \xdef\currentprevsolutionanswer{\UnlimitedCurrentAnswer}%
    % moreinfo 没有设置 label 参数，
    \ifx\currentmode\c!answer\ifmode_showmore
      \dousestyleparameter    {\p_currentparameter{moreinfostyle}}%
      \dousecolorparameter    {\p_currentparameter{moreinfocolor}}%
      \startmoreexaminfo\p_currentparameter\endcsname{moreinfo}\stopmoreexaminfo
    \fi\fi
  \endgroup
  \allowbreak
  \ifdefined\currentprevpoint\else
    \edef\currentprevpoint{\p_currentparameter\c!point}\fi
  \ifdefined\currentprevanswer
    \edef\currentprevanswer{\p_currentparameter\c!answer}\else
    \edef\currentprevanswer{\p_currentparameter\c!answer}%
  \fi
  \removeunwantedspaces\allowbreak
}

\def\p_pass_currentlabel[#1]{\p_assign_currentlabel[#1,,]}
\def\p_assign_currentlabel[#1,#2,#3]#4%
 {\def\left_assignedlabel {#1}%
  \def\right_assignedlabel{#2}}

\def\correct#1{#1\collectanswer{#1}}%定义可以收集答案的命令，该命令将会累积收集答案

