     showanswer=>{\mode_showanswertrue},
     \v!default=>{\mode_showanswerfalse},
     \v!unknown=>\showmessage\m!basicexam{1}{showanswer},
]

\processallactionsinset[\currentmoduleparameter{showpoint}][
      showpoint=>{\mode_showpointtrue},
     \v!default=>{\mode_showpointtrue},
     \v!unknown=>\showmessage\m!basicexam{1}{showpoint},
]

\processallactionsinset[\currentmoduleparameter{showscript}][
     showscript=>{\mode_showscripttrue},
     \v!default=>{\mode_showscriptfalse},
     \v!unknown=>\showmessage\m!basicexam{1}{showscript},
]

\processallactionsinset[\currentmoduleparameter{mode}][
     teacher=>{\enablemode[teacher]},
     student=>{\enablemode[student]},
       check=>{\enablemode[check]},
  \v!default=>{\enablemode[student]},
  \v!unknown=>\showmessage\m!basicexam{1}{mode},
]

\processallactionsinset[\currentmoduleparameter{layout}][
       twoup=>\lay_twouptrue,
        none=>\relax,
  \v!default=>\relax,
  \v!unknown=>\showmessage\m!basicexam{1}{layout},
]

\processallactionsinset[\currentmoduleparameter{footer}][
        none=>\relax,
  \v!default=>\hdr_defaulttrue,
  \v!unknown=>\showmessage\m!basicexam{1}{footer},
]

\doifelse{\currentmoduleparameter{libpath}}{}{
    \ctxlua{thirddata.basicexam_sql.set_libpath("")}
}{
