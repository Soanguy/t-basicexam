% 绘制圆圈
\startuseMPgraphic{mp:circle}
  numeric w;
  w := OverlayWidth ;  % 获取框架宽度
  draw fullcircle
    scaled .8w
    withpen pencircle scaled OverlayLineWidth
    withcolor OverlayLineColor ;
\stopuseMPgraphic

% 绘制叉号
\startuseMPgraphic{mp:cross}
  path p ;
  % 对角线路径（左下到右上）
  p := (-0.35, -0.35) -- (0.35, 0.35) ;
  draw p
    scaled OverlayWidth
    withpen pencircle scaled OverlayLineWidth
    withcolor OverlayLineColor ;
  % 对角线路径（左上到右下）
  p := (-0.35, 0.35) -- (0.35, -0.35) ;  % 左上到右下
  draw p
    scaled OverlayWidth
    withpen pencircle scaled OverlayLineWidth
    withcolor OverlayLineColor ;
\stopuseMPgraphic

\defineoverlay[circle][\useMPgraphic{mp:circle}]
\defineoverlay[cross] [\useMPgraphic{mp:cross}]

