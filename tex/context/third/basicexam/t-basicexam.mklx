  [xtable:questions]
  [option={stretch,width},split=yes,
   frame=off,
   header=repeat]

\startsetups xcell:header
  \bf \tt
\stopsetups

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%D \section{數據庫接口 / Database Interface}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\startluacode
    require("basicexam-sql")
    local basicexam_sql = thirddata.basicexam_sql
    
    local current_db = nil
    local current_db_path = nil
    
    function thirddata.basicexam.opendb(path)
        if current_db_path == path and current_db then
            return current_db
        end
        if current_db then
            basicexam_sql.close_database(current_db)
        end
        current_db_path = path
        current_db = basicexam_sql.open_database(path)
        return current_db
    end
    
    function thirddata.basicexam.closedb()
        if current_db then
            basicexam_sql.close_database(current_db)
            current_db = nil
            current_db_path = nil
        end
    end
    
    function thirddata.basicexam.getdb()
        return current_db
    end
    
    function thirddata.basicexam.search_questions_lua(filters, options)
        if not current_db then
            context("Error: database not opened")
            return
        end
        basicexam_sql.reset_material_shown()
        local questions = basicexam_sql.search_questions(current_db, filters)
        if questions then
            for i, q in ipairs(questions) do
                basicexam_sql.render_question(current_db, q, options)
            end
        end
    end
    
    function thirddata.basicexam.add_material_lua(title, content, author, source)
        if not current_db then
            return nil
        end
        return basicexam_sql.add_material(current_db, {
            title = title or "",
            content = content or "",
            author = author or "",
            source = source or ""
        })
    end
    
    function thirddata.basicexam.get_material_id_by_title(title)
        if not current_db then
            return nil
        end
        local m = basicexam_sql.get_material_by_title(current_db, title)
        return m and m.id
    end
    
    function thirddata.basicexam.add_question_lua(qtype, content, point, answer, explanation, source, year, material_id)
        if not current_db then
            return nil
        end
        return basicexam_sql.add_question(current_db, {
            type = qtype,
            content = content,
            point = point or 1,
            answer = answer or "",
            explanation = explanation or "",
            source = source or "",
            year = year,
            material_id = material_id and tonumber(material_id) or nil
        })
    end
    
    function thirddata.basicexam.add_tag_lua(qid, tag)
        if not current_db or not qid or not tag then
            return nil
        end
        for t in string.gmatch(tag, "[^,]+") do
            local trimmed = t:gsub("^%s*(.-)%s*$", "%1")
            if trimmed ~= "" then
                basicexam_sql.add_question_tag(current_db, qid, trimmed)
            end
        end
    end
    
    function thirddata.basicexam.add_choice_lua(qid, content, is_correct)
        if not current_db or not qid then
            return nil
        end
        return basicexam_sql.add_answer(current_db, qid, content, is_correct, 0)
    end
    
    function thirddata.basicexam.add_qitem_lua(qid, content, answer, explanation)
        if not current_db or not qid then
            return nil
        end
        return basicexam_sql.add_answer(current_db, qid, content, false, 0, answer, explanation)
    end
    
    function thirddata.basicexam.render_material_by_id(id, options)
        if not current_db then
            return
        end
        local m = basicexam_sql.get_material(current_db, id)
        if m then
            basicexam_sql.render_material_with_questions(current_db, m, options or {showanswer=true, showpoint=true})
        end
    end
    
    function thirddata.basicexam.render_material_by_title(title, options)
        if not current_db then
            return
        end
        local m = basicexam_sql.get_material_by_title(current_db, title)
        if m then
            basicexam_sql.render_material_with_questions(current_db, m, options or {showanswer=true, showpoint=true})
        end
    end
    
    function thirddata.basicexam.render_all_questions(options)
        if not current_db then
            context("Error: database not opened")
            return
        end
        options = options or {}
        basicexam_sql.reset_material_shown()
        local questions = basicexam_sql.get_all_questions(current_db)
        if questions then
            if options.showrawinfo then
                basicexam_sql.render_questions_table(current_db, questions)
            else
                for i, q in ipairs(questions) do
                    basicexam_sql.render_question(current_db, q, {showanswer=true, showpoint=true})
                end
            end
        end
    end
    
    function thirddata.basicexam.get_question_count_by_type(qtype)
        if not current_db then
            return 0
        end
        local questions = basicexam_sql.search_questions(current_db, {type=qtype})
        return questions and #questions or 0
    end
\stopluacode

\installnamespace {dbquestion}

\installcommandhandler \????dbquestion {dbquestion} \????dbquestion

\setupdbquestion
  [database=,
   id=,
   tag=,
   type=,
   showanswer=true,
   showpoint=true]

\unexpanded\def\opendatabase{\dosingleempty\do_opendatabase}

\def\do_opendatabase[#1]{%
    \begingroup
    \getdummyparameters[#1]%
    \ctxlua{thirddata.basicexam.opendb("\dummyparameter{path}")}%
    \endgroup
}

\unexpanded\def\closedatabase{%
    \ctxlua{thirddata.basicexam.closedb()}%
}

\newcount\c_db_material_id
\newcount\c_db_question_id

\unexpanded\def\addquestion{\dosingleempty\do_addquestion}

\def\do_addquestion[#1]#2{%
    \begingroup
    \getdummyparameters[#1]%
    \ctxlua{%
        local qtype = "\dummyparameter{type}"
        if qtype == "material" then
            local mid = thirddata.basicexam.add_material_lua(
                "\dummyparameter{title}",
                "\luaescapestring{#2}",
                "\dummyparameter{author}",
                "\dummyparameter{source}")
            tex.setcount("global", "c_db_material_id", mid or 0)
        else
            local material = "\dummyparameter{material}"
            local material_id = nil
            if material ~= "" then
                material_id = tonumber(material) or thirddata.basicexam.get_material_id_by_title(material)
            end
            local point = "\dummyparameter{point}"
            local year = "\dummyparameter{year}"
            local qid = thirddata.basicexam.add_question_lua(
                qtype,
                "\luaescapestring{#2}",
                point ~= "" and point or nil,
                "\dummyparameter{answer}",
                "\dummyparameter{explanation}",
                "\dummyparameter{source}",
                year ~= "" and year or nil,
                material_id)
            tex.setcount("global", "c_db_question_id", qid or 0)
            local tag = "\dummyparameter{tag}"
            if tag ~= "" and qid then
                thirddata.basicexam.add_tag_lua(qid, tag)
            end
        end
    }%
    \endgroup
}

\unexpanded\def\addchoice{\dosingleempty\do_addchoice}

\def\do_addchoice[#1]#2{%
    \begingroup
    \ctxlua{thirddata.basicexam.add_choice_lua(
        \the\c_db_question_id,
        "\luaescapestring{#2}",
        "#1" == "*")}%
    \endgroup
}

\unexpanded\def\addqitem{\dosingleempty\do_addqitem}

\def\do_addqitem[#1]#2{%
    \begingroup
    \getdummyparameters[#1]%
    \ctxlua{thirddata.basicexam.add_qitem_lua(
        \the\c_db_question_id,
        "\luaescapestring{#2}",
        "\dummyparameter{answer}",
        "\dummyparameter{explanation}")}%
    \endgroup
}

\unexpanded\def\initdatabase{\dosingleempty\do_initdatabase}

\def\do_initdatabase[#1]{%
    \begingroup
    \getdummyparameters[#1]%
    \ctxlua{os.remove("\dummyparameter{path}")}%
    \ctxlua{thirddata.basicexam.opendb("\dummyparameter{path}")}%
    \endgroup
}

\unexpanded\def\getallquestions{\dosingleempty\do_getallquestions}

\def\do_getallquestions[#1]{%
    \begingroup
    \getdummyparameters[#1]%
    \ctxlua{thirddata.basicexam.render_all_questions({showrawinfo="\dummyparameter{showrawinfo}"=="yes"})}%
    \endgroup
}

\unexpanded\def\getquestioncount#1{%
    \ctxlua{context(tostring(thirddata.basicexam.get_question_count_by_type("#1")))}%
}

\unexpanded\def\getmaterial{\dosingleempty\do_getmaterial}

\def\do_getmaterial[#1]{%
    \begingroup
    \getdummyparameters[#1]%
    \ctxlua{%
        local mid = "\dummyparameter{id}"
        local title = "\dummyparameter{title}"
        if mid ~= "" then
            thirddata.basicexam.render_material_by_id(mid)
        elseif title ~= "" then
            thirddata.basicexam.render_material_by_title(title)
        end
    }%
    \endgroup
}

\unexpanded\def\searchquestions{\dosingleempty\do_searchquestions}

\def\do_searchquestions[#1]{%
    \begingroup
    \getdummyparameters[#1]%
    \ctxlua{%
        local filters = {}
        local id = "\dummyparameter{id}"
        local tag = "\dummyparameter{tag}"
        local year = "\dummyparameter{year}"
        local source = "\dummyparameter{source}"
        local qtype = "\dummyparameter{type}"
        local showanswer = "\dummyparameter{showanswer}"
        local qitemid = "\dummyparameter{qitemid}"
        if id ~= "" then filters.id = id end
        if tag ~= "" then filters.tag = tag end
        if year ~= "" then filters.year = year end
        if source ~= "" then filters.source = source end
        if qtype ~= "" then filters.type = qtype end
        local options = {
            showanswer = showanswer == "yes",
            qitemid = qitemid ~= "" and tonumber(qitemid) or nil
        }
        thirddata.basicexam.search_questions_lua(filters, options)
    }%
    \endgroup
}

