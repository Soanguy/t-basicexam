\def\definepapertitlevariable#1{\begingroup% #1=element name
    \parindent0pt\relax
    \edef\p_align{\papertitleparameter{#1align}}%
    \edef\p_variable{\papertitleparameter{#1}}
    \dousealignparameter\p_align
    \papertitleparameter{before#1}%
    \usepapertitlestyleandcolor{#1style}{#1color}%
    \ifx\p_variable\empty\showmessage\m!basicexam{3}{#1}\else\p_variable\fi
    \papertitleparameter{after#1}%
    \iftok{\papertitleparameter{independent}}{false}\else\par\fi
    \endgroup}

\protected\tolerant\def\makepapertitle[#1]#*[#2]%
  {\begingroup\cdef\currentpapertitle{#1}%
  \ifarguments
    \or\setuppapertitle[#1]%
    \or\setuppapertitle[#1][#2]\fi
  \edef\currentpapertitlealternative{\papertitleparameter\c!alternative}%
  \ifcsname\currentpapertitlealternativehash\s!parent\endcsname \else
    \let\currentpapertitlealternative\s!default
  \fi
  \usesetupsparameter\papertitleparameter
  \edef\p_renderingsetup{\papertitlealternativeparameter\c!renderingsetup}%
  \usealignparameter\papertitleparameter
  \usepapertitlestyleandcolor\c!style\c!color
  \directsetup\p_renderingsetup
  \marking[subject]{\papertitleparameter{subject}%
                    \papertitleparameter{subjectsuffix}}%
  \marking[title]{\papertitleparameter\c!title}%
  \endgroup}

