}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%D \section{Unlimited Level Support}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\startluacode
  thirddata = thirddata or {}
  thirddata.basicexam_unlimited = thirddata.basicexam_unlimited or {}
  local U = thirddata.basicexam_unlimited

  U.check_mode = false
  local _report = logs.reporter("basicexam      ", "level")
  local function report(...) if U.check_mode then _report(...) end end

  function U.enable_check()
    U.check_mode = true
  end

  U.answer_tree = nil
  U.current_node = nil
  U.level_stack = {}
  U.chapter_counters = {}

  local function get_current_chapter()
    local sectiondata = structures.sections.current()
    if sectiondata and sectiondata.numberdata and sectiondata.numberdata.numbers then
      local numbers = sectiondata.numberdata.numbers
      local chapter = numbers[2] or numbers[1]
      if chapter then return tonumber(chapter) or 0 end
    end
    return 0
  end

  local function get_chapter_counter(chapter)
    if not U.chapter_counters[chapter] then
      U.chapter_counters[chapter] = 0
    end
    U.chapter_counters[chapter] = U.chapter_counters[chapter] + 1
    return U.chapter_counters[chapter]
  end

  local function get_id_prefix()
    local jobname = tex.jobname or "unknown"
    local chapter = get_current_chapter()
    return string.format("%s-%d", jobname, chapter)
  end

  --[[
  创建新节点
  参数:
    id - 节点ID
    env_type - 环境类型 (question, subquestion 等)
    depth - 层级深度
    parent - 父节点引用
  返回: 新创建的节点表
  ]]
  local function create_node(id, env_type, depth, parent)
    return {
      id = id or "unknown", env_type = env_type or "unknown", depth = depth, parent = parent,
      children = {}, totalnumber = 0, totalpoint = 0, currentpoint = 0,
      answer = "", order = "", is_leaf = false, child_counter = 0,
      extra_data = {},
    }
  end

  --[[
  初始化答案树: 创建根节点并设置当前节点为根
  ]]
  function U.init_tree()
    U.answer_tree = create_node("root", "root", 0, nil)
    U.answer_tree.is_leaf = false
    U.current_node = U.answer_tree
    U.level_stack = {U.answer_tree}
    report("Tree initialized")
  end

  --[[
  生成层级ID: 根据父节点ID和子节点计数器生成唯一ID
  格式: 文件名-章节-Q-N 或 文件名-章节-Q-N-M
  返回: 生成的ID字符串
  ]]
  local function generate_level_id()
    local parent = U.current_node
    local chapter = get_current_chapter()
    if not parent then
      local counter = get_chapter_counter(chapter)
      return string.format("%s-Q-%d", get_id_prefix(), counter)
    end
    parent.child_counter = parent.child_counter + 1
    if parent.id == "root" then
      local counter = get_chapter_counter(chapter)
      return string.format("%s-Q-%d", get_id_prefix(), counter)
    end
    return string.format("%s-%d", parent.id, parent.child_counter)
  end

  --[[
  生成题目序号: 生成完整的层级路径序号
  格式: depth=1 → "31", depth=2 → "31-1", depth=3 → "31-1-1"
  参数: parent - 父节点
  返回: 序号字符串
  ]]
  local function generate_order(parent)
    if not parent then return "1" end
    parent.order_counter = (parent.order_counter or 0) + 1
    local my_order = tostring(parent.order_counter)
    if parent.id == "root" then
      return my_order
    elseif parent.order and parent.order ~= "" then
      return parent.order .. "-" .. my_order
    else
      return my_order
    end
  end

  --[[
  更新所有祖先节点的统计信息
  参数:
    node - 起始节点
    delta_point - 分数变化量
    delta_number - 题目数量变化量
  ]]
  local function update_ancestors(node, delta_point, delta_number)
    while node do
      node.totalpoint = node.totalpoint + delta_point
      node.totalnumber = node.totalnumber + delta_number
      node = node.parent
    end
  end

  --[[
  收集节点下所有叶子节点的答案
  参数: node - 目标节点
  返回: 答案字符串，用逗号分隔
  ]]
  local function collect_leaf_answers(node)
    local answers = {}
    local function collect(n)
      if n.is_leaf and n.answer ~= "" then table.insert(answers, n.answer) end
      for _, c in ipairs(n.children) do collect(c) end
    end
    collect(node)
    return #answers > 0 and table.concat(answers, ", ") or ""
  end

  --[[
  保存节点数据到 dataset (.tuc文件): 用于在第二次编译时读取数据
  参数: node - 要保存的节点
  ]]
  local function save_to_dataset(node)
    local number = node.id:match("%-Q%-(%d+)") or node.id:match("Q%-(%d+)") or ""
    local data = {
      id = node.id, env = node.env_type, depth = node.depth, order = node.order or "",
      number = number,
      answer = node.is_leaf and node.answer or collect_leaf_answers(node),
      point = node.is_leaf and node.currentpoint or 0,
      totalpoint = node.totalpoint, totalnumber = node.totalnumber,
    }
    for k, v in pairs(node.extra_data) do data[k] = v end
    job.datasets.setdata { name = "UnlimitedDataset", tag = node.id, data = data }
  end

  --[[
  设置当前节点的额外数据
  TeX接口: UnlimitedSetExtraData(key, value)
  参数:
    key - 数据键名
    value - 数据值
  功能: 为当前节点存储额外的元数据（如选择题排版信息）
  ]]
  function U.set_extra_data(key, value)
    if U.current_node then
      U.current_node.extra_data[key] = value
      report("Set extra data: %s = %s", key, tostring(value))
    end
  end

  --[[
  获取当前节点的额外数据（实时）
  TeX接口: UnlimitedGetCurrentExtraData(key)
  参数: key - 数据键名
  返回: 数据值（当前编译中的数据）
  ]]
  function U.get_current_extra_data(key)
    if U.current_node and U.current_node.extra_data[key] then
      context(tostring(U.current_node.extra_data[key]))
    end
  end

  --[[
  进入新层级
  TeX接口: UnlimitedPushLevel(env_type)
  参数: env_type - 环境类型
  功能: 创建新节点并设为当前节点，同时维护环境栈用于嵌套检查
  ]]
  function U.push_level(env_type)
    if not U.answer_tree then U.init_tree() end
    local parent = U.current_node
    local new_node = create_node(generate_level_id(), env_type, parent.depth + 1, parent)
    new_node.order = generate_order(parent)
    table.insert(parent.children, new_node)
    U.current_node = new_node
    table.insert(U.level_stack, new_node)
    report("Pushed level %d: %s (%s), order=%s", new_node.depth, new_node.id, env_type, new_node.order)
  end

  --[[
  添加带分数的答案
  TeX接口: UnlimitedAddScoredAnswer(answer, point)
  参数:
    answer - 答案内容
    point - 分数
  功能: 为当前节点设置答案和分数，并更新祖先节点统计
  ]]
  function U.add_scored_answer(answer, point)
    if not U.current_node or #U.current_node.children > 0 then return end
    
    local is_first_time = not U.current_node.is_leaf
    
    if U.current_node.is_leaf then
      local old_pt = U.current_node.currentpoint
      U.current_node.currentpoint = 0
      U.current_node.answer = ""
      update_ancestors(U.current_node, -old_pt, 0)
    end
    
    local pt = tonumber(point) or 0
    U.current_node.answer = answer or ""
    U.current_node.currentpoint = pt
    U.current_node.is_leaf = true
    update_ancestors(U.current_node, pt, is_first_time and 1 or 0)
    save_to_dataset(U.current_node)
    report("Added answer: %s, point=%.1f, order=%s", answer, pt, U.current_node.order)
  end

  --[[
  退出当前层级
  TeX接口: UnlimitedPopLevel() 或 UnlimitedPopLevelChecked(env_type)
  参数: env_type - (可选) 期望的环境类型，提供时会检查环境名称是否匹配
  功能: 返回到父节点，如果当前节点有子节点则标记为非叶子
  ]]
  function U.pop_level(env_type)
    if #U.level_stack <= 1 then
      if env_type then
        report("ERROR: 多余的 \\stop%s，无对应 \\start%s", env_type, env_type)
      end
      return
    end
    
    if env_type then
      local current_env = U.current_node.env_type
      if current_env ~= env_type then
        report("ERROR: 禁止跨层闭合！当前最内层未闭合环境：%s，你试图提前闭合环境：%s", current_env, env_type)
        return
      end
    end
    
    local node = U.current_node
    
    if node.is_leaf and #node.children == 0 and node.answer == "" and node.currentpoint == 0 then
      report("WARNING: %s环境内容为空！ID=%s，层级=%d，请检查是否遗漏答案或分数", node.env_type, node.id, node.depth)
    end
    
    if #node.children > 0 and node.is_leaf then
      local pt = node.currentpoint
      node.is_leaf = false
      node.currentpoint = 0
      node.answer = ""
      
      local new_total, new_num = 0, 0
      for _, child in ipairs(node.children) do
        new_total = new_total + child.totalpoint
        new_num = new_num + child.totalnumber
      end
      node.totalpoint = new_total
      node.totalnumber = new_num
      
      if node.parent then
        node.parent.totalpoint = node.parent.totalpoint - pt + new_total
        node.parent.totalnumber = node.parent.totalnumber - (pt > 0 and 1 or 0) + new_num
      end
      report("Node recalculated: %.1f -> %.1f", pt, new_total)
    end
    
    save_to_dataset(node)
    table.remove(U.level_stack)
    U.current_node = U.level_stack[#U.level_stack]
    report("Popped to level %d", U.current_node.depth)
  end

  --[[
  检查是否有未闭合的环境
  TeX接口: UnlimitedCheckUnclosed()
  功能: 在文档结束时检查是否有未闭合的环境
  ]]
  function U.check_unclosed()
    if #U.level_stack > 1 then
      local unclosed_count = #U.level_stack - 1
      report("ERROR: 剩余 %d 层环境未闭合", unclosed_count)
      for i = 2, #U.level_stack do
        local node = U.level_stack[i]
        report("  未闭合: %s (层级 %d)", node.env_type, node.depth)
      end
    end
  end

  --[[
  通过ID查找节点
  参数: id - 节点ID
  返回: 节点表或nil
  ]]
  local function get_node(id)
    if not U.answer_tree then return nil end
    local function find(node, target)
      if node.id == target then return node end
      for _, child in ipairs(node.children) do
        local found = find(child, target)
        if found then return found end
      end
    end
    return find(U.answer_tree, id)
  end

  --[[
  获取节点的显示信息
  TeX接口: UnlimitedDisplayPoint(id), UnlimitedDisplayAnswer(id) 等
  参数: id - 节点ID
  返回: {point, answer, is_leaf, totalnumber}
  ]]
  function U.get_display(id)
    local node = get_node(id)
    if not node then return {point = 0, answer = "", is_leaf = false} end
    if node.is_leaf then
      return {point = node.currentpoint, answer = node.answer, is_leaf = true}
    end
    return {
      point = node.totalpoint,
      answer = collect_leaf_answers(node),
      is_leaf = false,
      totalnumber = node.totalnumber
    }
  end

  --[[
  TeX输出接口
  参数:
    id - 节点ID
    key - 要获取的属性 (point/answer/is_leaf/totalnumber)
  ]]
  function U.tex_get(id, key)
    local d = U.get_display(id)
    if key == "point" then
      context(d.point > 0 and (d.point == math.floor(d.point) and d.point or string.format("%.1f", d.point)) or 0)
    elseif key == "answer" then context(d.answer)
    elseif key == "is_leaf" then context(d.is_leaf and "true" or "false")
    elseif key == "totalnumber" then context(d.totalnumber or 0)
    elseif key == "order" then context(d.order or "")
    end
  end

  --[[
  获取指定 structure level 的统计信息
  参数: 
    level - structure level (1=chapter, 2=section, etc.)
    number - 该层级的编号
  返回: {totalnumber, totalpoint, leafnumber}
  ]]
  function U.get_structure_stats(level, number)
    local jobname = tex.jobname or "unknown"
    local prefix
    if level == 1 then
      prefix = string.format("%s-%d-Q-", jobname, number)
    else
      prefix = string.format("%s-", jobname)
      local sectiondata = structures.sectiondata
      if sectiondata then
        for _, data in ipairs(sectiondata) do
          if data.numberdata and data.numberdata.numbers then
            local nums = data.numberdata.numbers
            if nums[level] == number then
              local ref = nums[2] or nums[1]
              prefix = string.format("%s-%d-", jobname, ref)
              break
            end
          end
        end
      end
    end
    
    local stats = {totalnumber = 0, totalpoint = 0, leafnumber = 0}
    
    local function count_node(node)
      if node.id and prefix and node.id:find(prefix, 1, true) then
        if node.parent and node.parent.id == "root" then
          stats.totalnumber = stats.totalnumber + 1
          stats.totalpoint = stats.totalpoint + node.totalpoint
          if node.is_leaf then
            stats.leafnumber = stats.leafnumber + 1
          end
        end
      end
      for _, child in ipairs(node.children) do count_node(child) end
    end
    
    if U.answer_tree then count_node(U.answer_tree) end
    return stats
  end

  --[[
  获取当前 structure 的统计信息
  参数: level - structure level (1=chapter, 2=section, etc.)
  返回: {totalnumber, totalpoint, leafnumber}
  ]]
  function U.get_current_structure_stats(level)
    local sectiondata = structures.sections.current()
    if sectiondata and sectiondata.numberdata and sectiondata.numberdata.numbers then
      local numbers = sectiondata.numberdata.numbers
      local number = numbers[level] or numbers[2] or numbers[1]
      if number then
        return U.get_structure_stats(level, tonumber(number) or 0)
      end
    end
    return {totalnumber = 0, totalpoint = 0, leafnumber = 0}
  end

  --[[
  TeX接口: 获取 structure 统计
  参数:
    level - structure level (1=chapter, 2=section)
    number - 该层级的编号 (可选，不提供则使用当前 structure)
    key - 要获取的属性 (totalnumber/totalpoint/leafnumber)
  ]]
  function U.tex_get_structure(level, number, key)
    local stats
    if number and number ~= "" then
      stats = U.get_structure_stats(tonumber(level) or 1, tonumber(number) or 0)
    else
      stats = U.get_current_structure_stats(tonumber(level) or 1)
    end
    report("Structure stats (level=%s, number=%s): totalnumber=%s, totalpoint=%s, leafnumber=%s", 
      level, number or "current", stats.totalnumber, stats.totalpoint, stats.leafnumber)
    if key == "totalnumber" then context(stats.totalnumber)
    elseif key == "totalpoint" then context(stats.totalpoint)
    elseif key == "leafnumber" then context(stats.leafnumber)
    end
  end

  --[[
  获取当前深度
  TeX接口: UnlimitedDepth()
  返回: 当前层级深度 (0=根)
  ]]
  function U.get_depth() return U.current_node and U.current_node.depth or 0 end

  --[[
  获取当前节点ID
  TeX接口: UnlimitedCurrentID()
  返回: 当前节点ID字符串
  ]]
  function U.get_current_id() return U.current_node and U.current_node.id or "" end

  --[[
  调试输出树结构
  TeX接口: UnlimitedDebug()
  ]]
  function U.debug_tree()
    local function truncate(str, max_len)
      if not str or str == "" then return string.rep(" ", max_len) end
      str = tostring(str)
      if #str > max_len then
        return string.sub(str, 1, max_len - 3) .. "..."
      else
        return str .. string.rep(" ", max_len - #str)
      end
    end
    
    local function format_num(num, width)
      local str = string.format("%.1f", num or 0)
      if #str > width then
        str = string.sub(str, 1, width)
      end
      return string.rep(" ", width - #str) .. str
    end
    
    local function show(node, depth, is_last, prefix)
      if node.depth == 0 then
        report("Answer Tree")
        report("────────────────────────────────────────────────────────────────────────────────")
      else
        local connector = is_last and "└── " or "├── "
        local order_str = truncate(node.order, 8)
        local answer_str = truncate(node.is_leaf and node.answer or "", 15)
        local point_str = format_num(node.is_leaf and node.currentpoint or 0, 5)
        local total_str = format_num(node.totalpoint, 5)
        local num_str = string.format("%2d", node.totalnumber or 0)
        
        report("%s%s%s│ ans:%s│ pt:%s│ tot:%s│ n:%s",
          prefix, connector, order_str, answer_str, point_str, total_str, num_str)
      end
      
      local child_prefix = prefix .. (node.depth == 0 and "" or (is_last and "    " or "│   "))
      for i, child in ipairs(node.children) do
        show(child, depth + 1, i == #node.children, child_prefix)
      end
    end
    
    if U.answer_tree then 
      show(U.answer_tree, 0, true, "")
    end
    report("────────────────────────────────────────────────────────────────────────────────")
  end

  --[[
  导出答案到TSV文件
  TeX接口: UnlimitedExport(filename)
  参数: filename - 输出文件名
  ]]
  function U.export_answers(filename)
    local file = io.open(filename, "w")
    if not file then return report("ERROR: Cannot open %s", filename) end
    local T = string.char(9)
    file:write("depth", T, "id", T, "env", T, "order", T, "answer", T, "point", T, "totalpoint", T, "totalnumber\n")
    local function write_node(node)
      if node.depth > 0 then
        file:write(node.depth, T, node.id, T, node.env_type, T,
          node.order, T,
          node.is_leaf and node.answer or "", T,
          string.format("%.1f", node.is_leaf and node.currentpoint or 0), T,
          string.format("%.1f", node.totalpoint), T,
          node.totalnumber, "\n")
      end
      for _, child in ipairs(node.children) do write_node(child) end
    end
    write_node(U.answer_tree)
    file:close()
    report("Exported to %s", filename)
  end

  function U.finalize_check()
    U.check_unclosed()
    if not U.check_mode then return end
    U.debug_tree()
    local tsvname = tex.jobname .. "-answers.tsv"
    U.export_answers(tsvname)
  end

  U.init_tree()
\stopluacode

\definedataset[UnlimitedDataset]

\appendtoks
  \ctxlua{thirddata.basicexam_unlimited.finalize_check()}
\to \everystoptext

% 进入新层级 % 用法: \UnlimitedPushLevel{question} % 自动生成唯一ID，创建新节点
\def\UnlimitedPushLevel#1{\ctxlua{thirddata.basicexam_unlimited.push_level([==[#1]==])}}

% 添加带分数的答案 % 用法: \UnlimitedAddScoredAnswer{A}{100} % 为当前节点设置答案和分数
\def\UnlimitedAddScoredAnswer#1#2{\ctxlua{thirddata.basicexam_unlimited.add_scored_answer([==[#1]==], [==[#2]==])}}

% 退出当前层级 % 返回父节点，有子节点则标记为非叶子
\def\UnlimitedPopLevel{\ctxlua{thirddata.basicexam_unlimited.pop_level()}}

% 退出当前层级（带环境名称检查）
% 用法: \UnlimitedPopLevelChecked{question}
\def\UnlimitedPopLevelChecked#1{\ctxlua{thirddata.basicexam_unlimited.pop_level([==[#1]==])}}

% 检查是否有未闭合的环境
\def\UnlimitedCheckUnclosed{\ctxlua{thirddata.basicexam_unlimited.check_unclosed()}}

% 获取当前深度 %输出数字
\def\UnlimitedDepth{\ctxlua{context(thirddata.basicexam_unlimited.get_depth())}}

% 获取当前节点ID %输出 Q-1, Q-2-1 等
\def\UnlimitedCurrentID{\ctxlua{context(thirddata.basicexam_unlimited.get_current_id())}}

% 保存当前节点ID到宏 % 用法: \UnlimitedSaveCurrentID\MyID % 之后可用 \MyID 引用此ID
\def\UnlimitedSaveCurrentID#1{\edef#1{\UnlimitedCurrentID}}

% 显示节点分数 % 用法: \UnlimitedDisplayPoint{Q-1} → 输出分数
\def\UnlimitedDisplayPoint#1{\ctxlua{thirddata.basicexam_unlimited.tex_get("#1", "point")}}

% 显示节点答案 % 用法: \UnlimitedDisplayAnswer{Q-1} → 输出答案
\def\UnlimitedDisplayAnswer#1{\ctxlua{thirddata.basicexam_unlimited.tex_get("#1", "answer")}}

% 判断是否叶子节点 % 用法: \UnlimitedIsLeaf{Q-1} → 输出 true/false
\def\UnlimitedIsLeaf#1{\ctxlua{thirddata.basicexam_unlimited.tex_get("#1", "is_leaf")}}

% 获取节点下题目总数 % 用法: \UnlimitedTotalNumber{Q-1} → 输出数字
\def\UnlimitedTotalNumber#1{\ctxlua{thirddata.basicexam_unlimited.tex_get("#1", "totalnumber")}}

% 获取节点 order % 用法: \UnlimitedGetOrder{Q-1} → 输出 order
\def\UnlimitedGetOrder#1{\ctxlua{thirddata.basicexam_unlimited.tex_get("#1", "order")}}

% 获取节点总分 (同DisplayPoint)
\def\UnlimitedTotalPoint#1{\UnlimitedDisplayPoint{#1}}

% 获取指定 structure level 的题目总数 % 用法: \UnlimitedStructureTotalNumber{1}{1} → 输出数字 (level 1=chapter, number=1)
\def\UnlimitedStructureTotalNumber#1#2{\ctxlua{thirddata.basicexam_unlimited.tex_get_structure(#1, "#2", "totalnumber")}}

% 获取指定 structure level 的总分 % 用法: \UnlimitedStructureTotalPoint{1}{1} → 输出分数
\def\UnlimitedStructureTotalPoint#1#2{\ctxlua{thirddata.basicexam_unlimited.tex_get_structure(#1, "#2", "totalpoint")}}

% 获取指定 structure level 的叶子节点数 % 用法: \UnlimitedStructureLeafNumber{1}{1} → 输出数字
\def\UnlimitedStructureLeafNumber#1#2{\ctxlua{thirddata.basicexam_unlimited.tex_get_structure(#1, "#2", "leafnumber")}}

% 获取当前 structure 的题目总数 % 用法: \UnlimitedCurrentStructureTotalNumber{1} → 输出数字
\def\UnlimitedCurrentStructureTotalNumber#1{\ctxlua{thirddata.basicexam_unlimited.tex_get_structure(#1, "", "totalnumber")}}

% 获取当前 structure 的总分 % 用法: \UnlimitedCurrentStructureTotalPoint{1} → 输出分数
\def\UnlimitedCurrentStructureTotalPoint#1{\ctxlua{thirddata.basicexam_unlimited.tex_get_structure(#1, "", "totalpoint")}}

% 获取当前 structure 的叶子节点数 % 用法: \UnlimitedCurrentStructureLeafNumber{1} → 输出数字
\def\UnlimitedCurrentStructureLeafNumber#1{\ctxlua{thirddata.basicexam_unlimited.tex_get_structure(#1, "", "leafnumber")}}

% 从dataset读取当前节点答案
\def\UnlimitedCurrentAnswer{\datasetvariable{UnlimitedDataset}{\UnlimitedCurrentID}{answer}}

% 从dataset读取当前节点分数
\def\UnlimitedCurrentPoint{\datasetvariable{UnlimitedDataset}{\UnlimitedCurrentID}{totalpoint}}

% 检查dataset中是否有数据 % 用法: \UnlimitedHasDataset{Q-1} → yes/no
\def\UnlimitedHasDataset#1{\doifelsesomething{\datasetvariable{UnlimitedDataset}{#1}{id}}{yes}{no}}

% 设置当前节点的额外数据 % 用法: \UnlimitedSetExtraData{totalitemnumber}{4} % 用于存储选择题排版信息等元数据
\def\UnlimitedSetExtraData#1#2{\ctxlua{thirddata.basicexam_unlimited.set_extra_data([==[#1]==], [==[#2]==])}}

% 获取当前节点的额外数据（实时，当前编译中） % 用法: \UnlimitedGetCurrentExtraData{totalitemnumber}
\def\UnlimitedGetCurrentExtraData#1{\ctxlua{thirddata.basicexam_unlimited.get_current_extra_data([==[#1]==])}}

% 从dataset获取节点的额外数据（需编译两次） % 用法: \UnlimitedGetExtraData{Q-1}{totalitemnumber}
\def\UnlimitedGetExtraData#1#2{\datasetvariable{UnlimitedDataset}{#1}{#2}}

% 输出树结构到日志
\def\UnlimitedDebug{\ctxlua{thirddata.basicexam_unlimited.debug_tree()}}

% 导出答案到TSV文件 % 用法: \UnlimitedExport{answers.tsv}
\def\UnlimitedExport#1{\ctxlua{thirddata.basicexam_unlimited.export_answers([==[#1]==])}}

\def\BasicExamPushLevel#parent#current{%
  \edef\currentparentenvironment{#parent}%
  \edef\currentchildenvironment{#current}%
  \UnlimitedPushLevel{#current}%
  \c_currentitemnumber = 0\relax
  \initcollectanswer
  \ifx\currentparentenvironment\s!choice
  \else
    \iftok{#parent}{close}%
      \hbox{\hsize\scratchdimen\noindent\strut
      \showpointoranswer[#parent][point]%
      \showpointoranswer[#parent][answer]}%
    \else
      \showpointoranswer[#parent][point]%
      \showpointoranswer[#parent][answer]%
    \fi
    \UnlimitedAddScoredAnswer{\currentanswer}{\currentpoint}%
  \fi
}

\def\BasicExamPopLevel{\UnlimitedPopLevelChecked\currentchildenvironment}

