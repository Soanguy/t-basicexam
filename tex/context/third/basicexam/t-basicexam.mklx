%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%D \section{打印答案 / Print answer / 答えの輸出}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\installnamespace {typeanswer}
\installnamespace {typeansweralternative}
\installnamespace {typeanswerrenderings}

\installcommandhandler \????typeanswer {typeanswer} \????typeanswer
\installcommandhandler \????typeansweralternative {typeansweralternative} \????typeansweralternative

\appendtoks
  \frozen\instance\protected\edefcsname \currenttypeanswer\endcsname{\directnamedtypeanswer[\currenttypeanswer]}%
\to \everydefinetypeanswer

\setuptypeanswer
  [chapter=0,
   start=1,
   stop=,
   total=,
   rows=,
   columns=,
   separator={ },
   left=,
   right=,
   before=,
   after=,
   alternative=list,
   ]

\newcount\c_typeanswer_index
\newcount\c_typeanswer_chapter
\newcount\c_typeanswer_start
\newcount\c_typeanswer_stop

\def\typeanswercurrentindex{\the\c_typeanswer_index}

\def\typeanswergetnumber{%
  \datasetvariable{UnlimitedDataset}%
    {\jobname-\the\c_typeanswer_chapter-Q-\the\c_typeanswer_index}%
    {number}}

\def\typeanswergetanswer{%
  \datasetvariable{UnlimitedDataset}%
    {\jobname-\the\c_typeanswer_chapter-Q-\the\c_typeanswer_index}%
    {answer}}

\def\typeanswergetpoint{%
  \datasetvariable{UnlimitedDataset}%
    {\jobname-\the\c_typeanswer_chapter-Q-\the\c_typeanswer_index}%
    {totalpoint}}

\def\typeanswergetdirect#1#2{%
  \datasetvariable{UnlimitedDataset}{\jobname-#1}{#2}}

\definetypeansweralternative
  [list]
  [\c!renderingsetup=\????typeanswerrenderings:list]

\definetypeansweralternative
  [table]
  [\c!renderingsetup=\????typeanswerrenderings:table]

\definetypeansweralternative
  [text]
  [\c!renderingsetup=\????typeanswerrenderings:text]

\definetypeansweralternative
  [direct]
  [\c!renderingsetup=\????typeanswerrenderings:direct]

\definetypeansweralternative
  [grid]
  [\c!renderingsetup=\????typeanswerrenderings:grid]

\tolerant\protected\def\directnamedtypeanswer[#1]#*[#2]#:#3{%
  \begingroup
  \edef\currenttypeanswer{#1}%
  \ifparameter#2\or\setupcurrenttypeanswer[#2]\fi
  \edef\p_chapter   {\typeanswerparameter{chapter}}%
  \edef\p_start     {\typeanswerparameter{start}}%
  \edef\p_stop      {\typeanswerparameter{stop}}%
  \edef\p_total     {\typeanswerparameter{total}}%
  \edef\p_rows      {\typeanswerparameter{rows}}%
  \edef\p_columns   {\typeanswerparameter{columns}}%
  \edef\p_separator {\typeanswerparameter{separator}}%
  \edef\p_left      {\typeanswerparameter{left}}%
  \edef\p_right     {\typeanswerparameter{right}}%
  \edef\p_before    {\typeanswerparameter{before}}%
  \edef\p_after     {\typeanswerparameter{after}}%
  \edef\p_alternative{\typeanswerparameter{alternative}}%
  \def\p_directarg{#3}%
  \ifnum\numexpr\p_chapter=0\relax
    \c_typeanswer_chapter=\numexpr\namedheadnumber{chapter}\relax
  \else
    \c_typeanswer_chapter=\numexpr\p_chapter\relax
  \fi
  \c_typeanswer_start  =\numexpr\p_start\relax
  \ifx\p_stop\empty
    \ifx\p_total\empty
      \c_typeanswer_stop=\c_typeanswer_start
    \else
      \c_typeanswer_stop=\numexpr\c_typeanswer_start+\p_total-1\relax
    \fi
  \else
    \c_typeanswer_stop=\numexpr\p_stop\relax
  \fi\par
  \edef\currenttypeansweralternative{\p_alternative}%
  \ifcsname\currenttypeansweralternativehash\s!parent\endcsname \else
    \edef\currenttypeansweralternative{list}%
  \fi
  \edef\p_renderingsetup{\typeansweralternativeparameter\c!renderingsetup}%
  \directsetup\p_renderingsetup
  \par
  \endgroup}

\startsetups[\????typeanswerrenderings:list]
  \startitemize[n,packed]
  \scratchcounter=\numexpr\c_typeanswer_stop-\c_typeanswer_start+1\relax
  \c_typeanswer_index=\c_typeanswer_start
  \dorecurse\scratchcounter{%
    \startitem
    \p_before
    （\typeanswergetpoint 分）\p_left\typeanswergetanswer\p_right
    \p_after
    \stopitem
    \advance\c_typeanswer_index by 1\relax}
  \stopitemize
\stopsetups

\startsetups[\????typeanswerrenderings:table]
  \ifx\p_rows\empty\def\p_rows{1}\fi
  \ifx\p_columns\empty\def\p_columns{5}\fi
  \ctxcommand{typeanswer_table(
    "\jobname",\the\c_typeanswer_chapter,
    \the\c_typeanswer_start,\the\c_typeanswer_stop,
    "\p_rows","\p_columns")}
\stopsetups

\startsetups[\????typeanswerrenderings:text]
  \scratchcounter=\numexpr\c_typeanswer_stop-\c_typeanswer_start+1\relax
  \c_typeanswer_index=\c_typeanswer_start
  \dorecurse\scratchcounter{%
    \p_before
    \typeanswergetnumber.\p_left\typeanswergetanswer\p_right
    \ifnum\numexpr\c_typeanswer_index<\c_typeanswer_stop\relax
      \p_separator
    \fi
    \p_after
    \advance\c_typeanswer_index by 1\relax}
\stopsetups

\startsetups[\????typeanswerrenderings:direct]
  \typeanswergetdirect{\p_directarg}{answer}
\stopsetups

\startsetups[\????typeanswerrenderings:grid]
  \ifx\p_rows\empty\def\p_rows{5}\fi
  \ifx\p_columns\empty\def\p_columns{2}\fi
  \ctxcommand{typeanswer_grid(
    "\jobname",\the\c_typeanswer_chapter,
    \the\c_typeanswer_start,\the\c_typeanswer_stop,
    "\p_rows","\p_columns")}
\stopsetups

\def\resetanswerid{\global\c_typeanswer_index=0\relax}

\startluacode
  local function get_dataset_value(id, field)
    local data = job.datasets.getdata("UnlimitedDataset", id)
    if data and data[field] then
      return tostring(data[field])
    end
    return ""
  end

  commands.typeanswer_table = function(jobname, chapter, start_idx, stop_idx, rows, cols)
    rows = tonumber(rows) or 1
    cols = tonumber(cols) or 5
    local idx = start_idx
    local prefix = string.format("%s-%d-Q-", jobname, chapter)
    context.bTABLE()
    context.bTR()
    for c = 1, cols do
      if idx <= stop_idx then
        context.bTD()
        context(get_dataset_value(prefix .. idx, "number"))
        context.eTD()
        idx = idx + 1
      end
    end
    context.eTR()
    idx = start_idx
    context.bTR()
    for c = 1, cols do
      if idx <= stop_idx then
        context.bTD()
        context(get_dataset_value(prefix .. idx, "answer"))
        context.eTD()
        idx = idx + 1
      end
    end
    context.eTR()
    context.eTABLE()
  end

  commands.typeanswer_grid = function(jobname, chapter, start_idx, stop_idx, rows, cols)
    rows = tonumber(rows) or 5
    cols = tonumber(cols) or 2
    local idx = start_idx
    local prefix = string.format("%s-%d-Q-", jobname, chapter)
    context.bTABLE()
    for r = 1, rows do
      if idx > stop_idx then break end
      context.bTR()
      for c = 1, cols do
        if idx > stop_idx then break end
        context.bTD()
        context(get_dataset_value(prefix .. idx, "number"))
        context.eTD()
        context.bTD()
        context(get_dataset_value(prefix .. idx, "answer"))
        context.eTD()
        idx = idx + 1
      end
      context.eTR()
    end
    context.eTABLE()
  end
\stopluacode

%D Usage examples:
%D \starttyping
%D % List format (default):
%D \typeanswer[start=1,total=30]
%D
%D % Table format (ID row, Answer row):
%D \typeanswer[method=table,start=1,total=30,rows=6,columns=5]
%D
%D % Table alt format (ID and Answer in same row):
%D \typeanswer[method=table,layout=alt,start=1,total=10,rows=5,columns=2]
%D
%D % Direct access:
%D \typeanswer[method=direct]{Q-5}
%D
%D % Custom separator:
%D \typeanswer[start=1,total=10,separator={; }]
%D
%D % Hide ID:
%D \typeanswer[start=1,total=30,showid=no]
%D \stoptyping
\definetypeanswer[typeanswer]
%%%%
\startluacode
  -- Function to draw matching lines with labels
  function MP.lianxian(widthes, sort_code, before_items, after_items)
    local before_list = string.explode(before_items, ",")
    local after_list = string.explode(after_items, ",")
    local widthes_list = utilities.parsers.settings_to_array(widthes)
    local sort_code_list = {}

    -- Parse sort_code into a numeric list
    for i, line in ipairs(string.explode(sort_code)) do
      sort_code_list[i] = tonumber(line)
    end

    -- Define anchor points
    mp.fprint([[pair a[];]])

    -- Draw labels and set anchor points
    for i, line in ipairs(sort_code_list) do
      local before_label = string.strip(before_list[i])
      local after_label = string.strip(after_list[line])

      mp.fprint([[a[%s] := (0, -(bbheight(currentpicture)+BaseLineSkip));]], i)
      mp.fprint([[label.lft(textext("\hbox{\strut %s}"), a[%s]);]],before_label, i)
      mp.fprint([[label.rt(textext("\hbox{\strut %s}"), a[%s]) shifted (%s,0);]],after_label, i, widthes_list[2])
      end

    -- Draw connecting lines
    for i, line in ipairs(sort_code_list) do
      mp.fprint([[draw a[%s]--a[%s]+(%s,0) withcolor red;]], i, line, widthes_list[2])
    end
  end

  return MP.lianxian
\stopluacode

% Macro to simplify calling the Lua function
\def\lianxian[#1][#2]#3#4{%
  \dontleavehmode
  \startMPcode
    lua.MP.lianxian("#1", "#2", "#3", "#4");
  \stopMPcode
}

