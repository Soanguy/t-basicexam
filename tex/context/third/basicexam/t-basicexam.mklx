    \frozen\instance\protected\edefcsname\e!start\currentexaminfo\endcsname{\framed_examinfo_start[\currentexaminfo]}%
    \frozen\instance\protected\edefcsname\e!stop \currentexaminfo\endcsname{\framed_examinfo_stop                   }%
\to \everydefineexaminfo

\unexpanded\def\framed_examinfo_start[#1]%
 {\bgroup\edef\currentexaminfo{#1}%
  \edef\currentexaminfoalternative{\examinfoparameter\c!alternative}%
  \ifcsname\currentexaminfoalternativehash\s!parent\endcsname \else
    \let\currentexaminfoalternative\s!default
  \fi
  \examinfoparameter\c!before
  \usesetupsparameter\examinfoparameter
  \edef\p_renderingsetup{\examinfoalternativeparameter\c!renderingsetup}%
  \useexaminfostyleandcolor\c!style\c!color
  \directsetup\p_renderingsetup
  \bgroup\examinfoparameter\c!left}

\unexpanded\def\framed_examinfo_stop%
 {\examinfoparameter\c!right\egroup
  \examinfoparameter\c!after\egroup}

