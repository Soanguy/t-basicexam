%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%D \section{设置 question 环境}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\tolerant\protected\def\setup_itemgroup_temp[#1][#2][#3]{%
  \toks0={#2}\toks1={#3}%
  \ifempty\toks1
    \ifempty\toks0\else
      \ifhastok={#2}\setupitemgroup[env!#1][#2]\else
                    \setupitemgroup[env!#1][#2]\fi
    \fi
  \else
    \ifhastok={#3}\setupitemgroup[env!#1][#2]%
                  \setupitemgroup[env!#1][#3]\else
                  \setupitemgroup[env!#1][#2,#3]\fi
  \fi
  \startitemgroup[env!#1][\p_option]%
}

\permanent\tolerant\protected\def\startnamedquestion[#S#category]#spacer[#S#options]#spacer[#S#settings]%
  {\begingroup % (1)
    \nofarguments\lastarguments
    \cdef\currentitemgroup{#category}% no nested mixing of itemgroups
    \let\currentparentitemgroup\currentitemgroup
    \global\advanceby\c_strc_itemgroups_nesting\plusone
    \def\currentitemlevel{\the\c_strc_itemgroups_nesting}%
    \expanded{\chaintocurrentitemgroup{\currentparentitemgroup:\currentitemlevel}}%
    \cdef\currentitemgroup{\currentparentitemgroup:\currentitemlevel}%
    \edef\p_itemgroups_options{\itemgroupparameter\c!option}%
    \lettonothing\p_itemgroups_extra_options
    \ifcase\nofarguments
      \strc_itemgroups_start_indeed{}%
    \or
      \strc_itemgroups_start_indeed{}%
    \or
      \ifhastok={#options}%
        \strc_itemgroups_start_indeed{#options}%
      \else
        \edef\p_itemgroups_extra_options{#options}%
        \strc_itemgroups_start_indeed{}%
      \fi
    \or
       \ifhastok={#options}%
        \strc_itemgroups_start_indeed{#options}%
      \else
        \edef\p_itemgroups_extra_options{#options}%
        \strc_itemgroups_start_indeed{#settings}%
      \fi
    \fi
    \edef\currentexamenvironment%
      {\iftok{\itemgroupparameter\c!class}{\s!problem}\s!problem
        \else
          \iftok{\itemgroupparameter\c!class}{\s!writing}\s!writing
          \else
            question\fi\fi}%
    \doiftrue{itemgroup}\c!reset{\setcounter[itemgroup:env!#1][0]}%
    \ifx\currentexamenvironment\s!problem\else
      \item[\itemgroupparameter\c!reference]%
      \BasicExamPushLevel{itemgroup}\currentexamenvironment
    \fi
    \useitemgroupstyleandcolor\c!textstyle\c!textcolor
    \save_question_order
}

\permanent\tolerant\protected\def\stopnamedquestion{%
  \ifx\currentexamenvironment\s!problem\else\BasicExamPopLevel\fi
  \stopitemgroup}

\tolerant\protected\def\directnamedquestion[#1]#*[#S#2]#*[#S#3]#*%
 {\groupedcommand{\startnamedquestion[#1][#2][#3]}{\stopnamedquestion}}

\permanent\tolerant\protected\def\definequestion[#1][#2][#3]{
  \nofarguments\lastarguments
  \ifcase\nofarguments\or\defineitemgroup[env!#1]\or\defineitemgroup[env!#1][#2]\or\defineitemgroup[env!#1][#2][#3]\fi
  \frozen\instance\protected\edefcsname         #1\endcsname{\directnamedquestion[env!#1]}%
  \frozen\instance\protected\edefcsname\e!start #1\endcsname{\startnamedquestion [env!#1]}%
  \frozen\instance\protected\edefcsname\e!stop  #1\endcsname{\stopnamedquestion}%
}

\permanent\tolerant\protected\def\setupquestion[#S#category]#spacer[#S#levels]#spacer[#S#options]#spacer[#S#settings]% category level|each options|settings settings|options
  {\ifarguments
     % nothing to set up
   \or
     \edef\strc_itemgroups_setup_what{#levels}%
     \strc_itemgroups_normal_setup[#category]% == settings \setupquestion[key=value]
   \or
     \edef\strc_itemgroups_setup_what{#levels}%
     \strc_itemgroups_setup_each{env!#category}{#levels}%
   \or
     \edef\strc_itemgroups_setup_what{#levels}%
     \ifx\strc_itemgroups_setup_what\v!each
       \strc_itemgroups_setup_each{env!#category}{#options}%
     \else
       \strc_itemgroups_setup_list{#levels}{env!#category}{#options}%
     \fi
   \or
     \edef\strc_itemgroups_setup_what{#levels}%
     \ifx\strc_itemgroups_setup_what\v!each
       \strc_itemgroups_setup_each{env!#category}{#options}%
       \strc_itemgroups_setup_each{env!#category}{#settings}%
     \else
       \strc_itemgroups_setup_list{#levels}{env!#category}{#options}%
       \strc_itemgroups_setup_list{#levels}{env!#category}{#settings}%
     \fi
   \fi}

\defineframed[MiddleFramed] [width=1.5em,rulethickness=0pt,strut=no,height=.8\baselineskip,
                             background=color,backgroundcolor=themecolor,
                             backgroundradius=5pt,frameradius=5pt,
                             foregroundcolor=white,foregroundstyle=ssx,align={lohi,center},
                             frame=on,framecolor=themecolor,corner=02,rulethickness=.5pt]
\defineframed[InnerFramed]  [MiddleFramed]
                            [background=color,backgroundcolor=white,
                             foregroundcolor=themecolor,
                             frame=on,framecorner=trb,framecolor=themecolor,corner=04,]
\def\ExampleNumber#1%
    {\dontleavehmode\setuplocalinterlinespace[stretch=1]\lower1pt\hbox{\MiddleFramed{例}\InnerFramed{\kern-.5pt\relax #1}}}
\def\ExampleNumberII#1%
    {\dontleavehmode\setuplocalinterlinespace[stretch=1]\lower1pt\hbox{\MiddleFramed[backgroundradius=1pt,frameradius=1pt]{例}\InnerFramed[backgroundradius=1pt,frameradius=1pt]{#1}}}
\def\QuestionNumber#1%
    {\dontleavehmode\setuplocalinterlinespace[stretch=1]\lower1pt\hbox{\MiddleFramed{题}\InnerFramed{\kern-.5pt\relax #1}}}
\def\QuestionNumberII#1%
    {\dontleavehmode\setuplocalinterlinespace[stretch=1]\lower1pt\hbox{\MiddleFramed[backgroundradius=1pt,frameradius=1pt]{题}\InnerFramed[backgroundradius=1pt,frameradius=1pt]{#1}}}

\defineconversion [ExampleNumberI]   [\ExampleNumber]
\defineconversion [ExampleNumberII]  [\ExampleNumberII]
\defineconversion [QuestionNumberI]  [\QuestionNumber]
\defineconversion [QuestionNumberII] [\QuestionNumberII]

