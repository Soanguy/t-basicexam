\def\definelexicalinfocommand#1#2{%
  \setvalue{#1}##1%
    {\dontleavehmode
     \thinspace{\lexicalinnerframe{#2}%
     \uselexicalentrystyleandcolor\c!infostyle\c!infocolor
     ##1}\thinspace}}

\installnamespace          {lexicalentry}
\installcommandhandler \????lexicalentry     {lexicalentry}     \????lexicalentry
\installcounterassociation {lexicalentry}

\newtoks\everylexicalentry

\appendtoks
   \synchronizelexicalentrycounters
\to \everysetuplexicalentry

\appendtoks
  % \frozen\instance\protected\edefcsname        \currentlexicalentry\endcsname{\namedlexicalentry}%
  \frozen\protected\instance\edefcsname\e!start\currentlexicalentry\endcsname{\startnamedlexicalentry[\currentlexicalentry]}%
  \frozen\protected\instance\letcsname \e!stop \currentlexicalentry\endcsname \stopnamedlexicalentry
  \registerlexicalentrycounter{\currentlexicalentry}
  \definecounter[\currentlexicalentry]%
\to \everydefinelexicalentry

\appendtoks
  \definelexicalinfocommand{antonym} {\lexicalentryparameter{antonymlabel}}%
  \definelexicalinfocommand{example} {\lexicalentryparameter{examplelabel}}%
  \definelexicalinfocommand{refer}   {\lexicalentryparameter{referlabel}}%
  \definelexicalinfocommand{junction}{\lexicalentryparameter{junctionlabel}}%
  \resetcounter[lexicalgrammar]%
  \resetcounter[lexicaljunction]%
  \resetcounter[lexicalmeaning]%
  \resetcounter[lexicalsummary]%
  \resetcounter[lexicalexample]%
  \resetcounter[lexicalcomparing]%
  \resetcounter[itemgroup:env!question]%
  \def\hantext#1{{\language[hans]\hwx\kern -.5em ｜ #1}}%
  \def\lexicalemph#1{{\ss\underbar{#1}}}
\to \everylexicalentry

\setuplexicalentry[
  \c!style=\definedfont[Serif],
  \c!after=\blank[halfline],
  \c!prefix=no,
  \c!start=0,
  \c!numberconversion=cn,
  \c!way=\v!by\v!chapter,
  \c!numberstopper=、,
  \c!textstyle=ssa,
  \c!textcolor=blue,
  \c!infostyle=ssx,
  antonymlabel=対,
  examplelabel=例,
  referlabel=参考,
  junctionlabel=接続,
  alias=〜,
  entrycommand=,]

\tolerant\protected\def\startnamedlexicalentry[#1]#*[#2]#*#:#3%
 {\begingroup
    \cdef\currentlexicalentry{#1}%
    \ifhastok={#2}\setuplexicalentry[#2]\fi
    \the\everylexicalentry
    \def\alias      {\lexicalentryparameter{alias}}%
    \edef\p_accent  {\lexicalentryparameter{accent}}%
    \edef\p_class   {\lexicalentryparameter{class}}%
    \edef\p_number  {\lexicalentryparameter{number}}%
    \edef\p_indexcmd{\lexicalentryparameter{indexcommand}}%
    \edef\p_indexcls{\lexicalentryparameter{indexclass}}%
    \edef\p_indexCLS{grammar}%
    \setupindenting[\lexicalentryparameter\c!indenting]%
    \lexicalentryparameter\c!before
    \uselexicalentrystyleandcolor\c!style\c!color
    \bgroup
      \uselexicalentrystyleandcolor\c!textstyle\c!textcolor
      \ifchknumber\lexicalentryparameter\c!number\or
        \setupcounter[\currentlexicalentry][number=\lexicalentryparameter\c!number]%
        \convertedcounter[\currentlexicalentry]%
        \incrementcounter[\currentlexicalentry]%
      \else
        \doiftrue{lexicalentry}{number}{%
          \incrementcounter[\currentlexicalentry]%
          \convertedcounter[\currentlexicalentry]}%
      \fi
      \lexicalentryparameter{entrycommand}{#3}%
    \egroup\penalty0
    \ifx\p_indexcmd\empty
      \ifx\p_indexcls\p_indexCLS
        \grammarindex{#3}%
        \functionindex{\lexicalentryparameter{function}+#3}%
      \else\entryindex{#3}\fi
    \else\lexicalentryparameter{indexcommand}{#3}\fi
    \textreference[#3]{#3}
    \ifhastok={#2}\bgroup
      \processcommacommand[\p_class]{\penalty0\thinspace\lexicaltagframe}%
      \processcommacommand[\p_accent]{\penalty0\thinspace\lexicaltagframe[width=\bodyfontsize]}\egroup
    \else\bgroup
      \processcommacommand[#2]{\penalty0\thinspace\lexicaltagframe}\egroup
    \fi
    \lexicalentryparameter\c!inbetween}

\def\stopnamedlexicalentry{%
  \lexicalentryparameter\c!after
  \endgroup}

\definelexicalentry[lexicalentry]  [state=stop,indenting=none]
\definelexicalentry[lexicalsyntax] [indexclass=grammar,indenting=none]

\defineitemgroup  [lexicallists]  [levels=4]
\setupitemgroup   [lexicallists]  [each] [before=,after=,left=,right=,width=1.5em,
                                          lefttext=,righttext=,
                                          indenting=no,stopper=,symalign=center,]
\setupitemgroup   [lexicallists]  [1]    [Cr:kata,,packed,joinedup]
\setupitemgroup   [lexicallists]  [2]    [CR:num, ,packed,joinedup]
\setupitemgroup   [lexicallists]  [3]    [Co:num, ,packed,joinedup]
\setupitemgroup   [lexicallists]  [4]    [R,      ,packed,joinedup][stopper=.]

\defineenumeration[lexicalenumeration]
\defineenumeration[lexicalgrammar]   [lexicalenumeration] [text={文法},  counter=grammarlists]
\defineenumeration[lexicalmeaning]   [lexicalenumeration] [text={意味},  counter=lexicalmeaning]
\defineenumeration[lexicaljunction]  [lexicalenumeration] [text={接続},  counter=lexicaljunction]
\defineenumeration[lexicalexample]   [lexicalenumeration] [text={例文},  counter=lexicalexample]
\defineenumeration[lexicalcomparing] [lexicalenumeration] [text={対比},  counter=lexicalcomparing]
\defineenumeration[lexicalsummary]   [lexicalenumeration] [text={まとめ},counter=lexicalsummary]

\setupenumeration[lexicalenumeration][
  distance=.5em,
  numbercommand=\groupedcommand{\raise1.5pt\hbox\bgroup\lexicalframe\bgroup}{\egroup\egroup},
  width=fit,hang=broad,
  alternative=hanging,
  indenting={yes,first,always,2em},
  before=\par,inbetween=,after=\par,]

% 当 example没有说明，而直接列举例文时：
% \setupenumeration[lexicalexample][alternative=top,inbetween=\leftskip 2em\vskip-.9\baselineskip,]

% \startlexicalentry[apple,名,accent,1]{太陽} \stoplexicalentry
% \startlexicalentry[number=true]{太陽} \stoplexicalentry
% \startlexicalentry[number=5]{太陽} \stoplexicalentry

% \startlexicalentry[class=名,accent=1]{太陽}
%   \startlexicallists
%     \item 太陽系の中心をなし、地球にもっとも近い恒星。お日さま。\antonym{太陰}/\example{太陰}/\refer{太陰}/\junction{太陰}
%     \item 光明・希望の象徴。「心の\alias」
%   \stoplexicallists
% \stoplexicalentry

%   \startlexicalexample ワインをは飲みますが、ビールをはのみません。\stoplexicalexample
%   \startlexicalexample ワインをは飲みますが、ビールをはのみません。\stoplexicalexample
%   \startlexicalexample
%     ワインをは飲みますが、ビールをはのみません。
%     \startlexicallists
%       \item 私はワインは飲みますが、ビールは飲みません。
%     \stoplexicallists
%   \stoplexicalexample
  
%   \startlexicalmeaning{Aの状態ではなくなるまでにBを完了する}\\
%     \junction{動詞辞書形・テイル形・ナイ形}\\
%     \junction{形容詞・形容動詞の連体形（現在肯定形・現在否定形）}\\
%     \junction{名詞＋の}
%     \startlexicallists
%       \item 明るいうちに、帰ったほうがいい。
%       \item 元気なうちに、世界一周旅行がしたい。
%     \stoplexicallists
%   \stoplexicalmeaning

%   \startlexicaljunction/\startlexicalcomparing/\startlexicalsummary
%     太陽系の中心をなし、地球にもっとも近い恒星。
%     \startlexicallists
%       \item 明るいうちに、帰ったほうがいい。
%       \item 元気なうちに、世界一周旅行がしたい。
%     \stoplexicallists
%   \stoplexicaljunction/\stoplexicalcomparing/\stoplexicalsummary
%   
% \stoplexicalgrammar

