\definemode[teacher][keep]
\definemode[student][keep]
\startmode[teacher]
  \mode_showanswertrue
  \mode_showpointtrue
  \setupfillin[empty=none]
\stopmode
\startmode[student]
  \mode_showanswerfalse
  \mode_showpointfalse
\stopmode

\startmode[check]
  \mode_showanswertrue
  \mode_showpointtrue
  \ctxlua{thirddata.basicexam_unlimited.enable_check()}
\stopmode

\def\showanswer{\mode_showanswertrue \setupanswer[showscript=false]}
\def\hideanswer{\mode_showanswerfalse\setupanswer[showscript=true]}

\def\showpoint        {\mode_showpointtrue}
\def\hidepoint        {\mode_showpointfalse}

\def\enableshowanswer {\mode_showanswertrue}
\def\disableshowanswer{\mode_showanswerfalse}

\def\enableshowpoint  {\mode_showpointtrue}
\def\disableshowpoint {\mode_showpointfalse}

\initcollectanswer
\doifmodeelse{student}{\setupfillin[n=8]}{\setupfillin[n=4]}

